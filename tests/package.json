{
  "name": "@seams-sdk/tests",
  "private": true,
  "type": "module",
  "scripts": {
    "check:chain-family-naming": "node scripts/check-chain-family-naming.mjs",
    "check:intended-mutation-self-check": "node scripts/check-intended-mutation-self-check.mjs",
    "check:intended-mutation-self-check:complete": "node scripts/check-intended-mutation-self-check.mjs --require-detected",
    "check:refactor88-test-ledger": "node scripts/check-refactor88-test-ledger.mjs",
    "check:refactor88-test-ledger:complete": "node scripts/check-refactor88-test-ledger.mjs --require-complete",
    "check:type-filename-source": "node scripts/check-type-filename-source.mjs",
    "preflight:intended-mutation-self-check": "node scripts/check-intended-mutation-self-check.mjs --preflight",
    "preflight:intended-mutation-self-check:ci": "node scripts/check-intended-mutation-self-check.mjs --preflight --ci",
    "setup:intended-google-oidc": "node scripts/setup-intended-google-oidc.mjs",
    "refresh:intended-google-token": "node scripts/refresh-intended-google-token.mjs",
    "seed:intended-local-console": "node scripts/seed-intended-local-console.mjs",
    "test": "pnpm -C .. build:sdk-full && playwright test --reporter=line",
    "test:lite": "pnpm -C .. build:sdk-full && playwright test -c playwright.lite.config.ts --reporter=line",
    "test:inline": "pnpm -C .. build:sdk-full && playwright test --reporter=line",
    "test:e2e": "pnpm -C .. build:sdk-full && playwright test ./e2e --reporter=line",
    "test:intended": "playwright test -c playwright.intended.config.ts --reporter=line",
    "test:intended:ci": "playwright test -c playwright.intended.ci.config.ts --reporter=line",
    "test:unit": "pnpm -C ../packages/sdk-server-ts run build && pnpm -C .. build:sdk-full && playwright test -c playwright.unit.config.ts --reporter=line",
    "test:router-surface": "playwright test -c playwright.router.config.ts --reporter=line",
    "test:source-guards": "pnpm run check:type-filename-source && pnpm -C .. build:sdk-full && playwright test -c playwright.source.config.ts --reporter=line",
    "test:integration:signing": "pnpm -C .. build:sdk-full && playwright test -c playwright.integration.config.ts --reporter=line",
    "test:threshold-core": "playwright test -c playwright.unit.config.ts ./unit/routerAbEcdsaHssNormalSigning.unit.test.ts ./unit/routerAbEcdsaHssPresignBridge.unit.test.ts ./unit/thresholdEd25519.presignPool.unit.test.ts --reporter=line",
    "test:threshold-ed25519:active-path": "playwright test -c playwright.relayer.config.ts ./relayer/link-device.prepare.test.ts ./relayer/email-recovery.prepare.test.ts --reporter=line && playwright test -c playwright.scripts.config.ts ./unit/thresholdEd25519.separatedRoles.script.unit.test.ts --reporter=line",
    "test:signers:gates": "pnpm -C .. build:sdk-full && playwright test ./unit/walletSessionReadiness.gate.unit.test.ts ./unit/thresholdEcdsa.commitQueue.unit.test.ts ./unit/walletIframeHost.signTempoCancel.unit.test.ts ./wallet-iframe/router.behavior.concurrent.test.ts --reporter=line",
    "test:signer-parity:rust": "pnpm -C .. build:sdk-full && playwright test ./unit/signerParity.rustPlatforms.unit.test.ts --workers=1 --reporter=line",
    "test:signer-parity:web-wasm-replay": "pnpm -C .. build:sdk-full && playwright test ./unit/signingVectors.webWasmReplay.integration.test.ts --workers=1 --reporter=line",
    "test:signer-parity": "pnpm run test:signer-parity:rust && pnpm run test:signer-parity:web-wasm-replay",
    "test:signer-parity:swift": "RUN_IOS_SWIFT_REPLAY=1 pnpm run test:signer-parity",
    "test:wallet-iframe": "playwright test ./wallet-iframe --reporter=line",
    "test:lit-components": "playwright test ./lit-components --reporter=line",
    "test:relayer": "playwright test -c playwright.relayer.config.ts --reporter=line",
    "test:unit:scripts": "playwright test -c playwright.scripts.config.ts --reporter=line",
    "show-report": "playwright show-report"
  },
  "devDependencies": {
    "@noble/curves": "^2.0.1",
    "@noble/ed25519": "^2.1.0",
    "@playwright/test": "^1.40.0",
    "@simplewebauthn/server": "^13.2.2",
    "@types/express": "^4.17.23",
    "express": "^4.21.2",
    "viem": "^2.38.6"
  }
}

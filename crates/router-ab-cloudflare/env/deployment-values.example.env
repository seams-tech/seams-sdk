# Store one copy outside the repository for each deployment target and set mode
# 600. The wallet-core preparation command generates deployment identities, tenant IDs,
# publishable keys, origins, D1 databases, Pages projects, and Secrets Store
# resources.
#
# Preparing or applying wallet-core for an initialized target requires the
# explicit --rotate flag because the generated wallet identities are
# custody-critical. Product apply uses its separate paired manifest.

# Required. Use a scoped token that can manage Workers, Pages, D1, Secrets
# Store, and the account metadata needed by the deployment.
CLOUDFLARE_API_TOKEN=<scoped-cloudflare-api-token>

# Required only when Wrangler can see more than one Cloudflare account.
# CLOUDFLARE_ACCOUNT_ID=<cloudflare-account-id>

# Optional NEAR gas sponsorship. Configure the funded account and its private
# key together. RELAYER_PUBLIC_KEY is optional because the Gateway can derive it
# from the private key.
# Public testnet live-demo deployments use this profile. Set an explicit
# testnet_service or mainnet_service profile for a service-only deployment.
# GATEWAY_RUNTIME_PROFILE=testnet_live_demo
# EMAIL_OTP_DELIVERY_MODE=demo_code_response
# RELAYER_ACCOUNT_ID=<funded-relayer.testnet>
# RELAYER_PRIVATE_KEY=<ed25519-private-key>
# RELAYER_PUBLIC_KEY=<ed25519-public-key>
# RELAYER_INITIAL_BALANCE_YOCTO=30000000000000000000000

# Optional Google OIDC / Email OTP support. Use provider_and_demo_code only
# after supplying a real Email OTP provider to the Gateway runtime.
# GOOGLE_OIDC_CLIENT_ID=<google-client-id>
# SEAMS_OIDC_EXCHANGE_JSON={"issuer":"..."}

# Optional EVM-family gas sponsorship. Executor keys must be funded on every
# configured chain.
# SPONSORED_EVM_EXECUTORS_JSON={"42431":{"sponsorPrivateKeyHex":"0x..."}}

# Optional SDK publication to R2. Omit all four to skip R2 publication.
# R2_ENDPOINT=https://<cloudflare-account-id>.r2.cloudflarestorage.com
# R2_BUCKET=w3a-sdk
# R2_ACCESS_KEY_ID=<r2-access-key-id>
# R2_SECRET_ACCESS_KEY=<r2-secret-access-key>

# Optional browser network overrides. The app has built-in staging defaults.
# VITE_TEMPO_RPC_URL=<tempo-rpc-url>
# VITE_TEMPO_EXPLORER=<tempo-explorer-url>
# VITE_TEMPO_FEE_TOKEN=<tempo-fee-token-address>
# VITE_ARC_RPC_URL=<arc-rpc-url>
# VITE_ARC_EXPLORER=<arc-explorer-url>

# Optional overrides. The bootstrap command otherwise provisions target-scoped
# Pages projects and derives their pages.dev origins.
# GATEWAY_ORIGIN=https://gateway.example.com
# VITE_APP_ORIGIN=https://app.example.com
# VITE_WALLET_ORIGIN=https://wallet.example.com
# VITE_RP_ID_BASE=example.com

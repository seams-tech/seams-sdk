# Router A/B GitHub Environment template.
# Copy these names into both the staging and production GitHub Environments.
# Do not source this file with real secrets.

# GitHub Environment variables.
# router:deploy:keygen generates the Router A/B public key values.
ROUTER_AB_JWT_ISSUER=https://issuer.example
ROUTER_AB_JWT_AUDIENCE=router-ab
ROUTER_AB_JWT_JWKS_URL=https://issuer.example/.well-known/jwks.json
ROUTER_AB_SIGNER_A_ENVELOPE_HPKE_PUBLIC_KEY=x25519:<64-lowercase-hex>
ROUTER_AB_SIGNER_B_ENVELOPE_HPKE_PUBLIC_KEY=x25519:<64-lowercase-hex>
ROUTER_AB_SIGNING_WORKER_SERVER_OUTPUT_HPKE_PUBLIC_KEY=x25519:<64-lowercase-hex>
ROUTER_AB_SIGNER_A_PEER_VERIFYING_KEY_HEX=<64-lowercase-hex>
ROUTER_AB_SIGNER_B_PEER_VERIFYING_KEY_HEX=<64-lowercase-hex>

# GitHub Environment secrets.
# router:deploy:keygen generates all private deployment identity keys below
# except the root-share wire secrets, which come from the provisioning ceremony.
CLOUDFLARE_API_TOKEN=<worker-deploy-token>
CLOUDFLARE_ACCOUNT_ID=<account-id>
SIGNER_A_ROOT_SHARE_WIRE_SECRET=mpc-prf-root-share-wire-v1:<hex-wire-secret>
SIGNER_A_ENVELOPE_HPKE_PRIVATE_KEY=hpke-x25519-private-v1:<64-lowercase-hex>
SIGNER_A_PEER_SIGNING_KEY=<32-byte-unpadded-base64url>
SIGNER_B_ROOT_SHARE_WIRE_SECRET=mpc-prf-root-share-wire-v1:<hex-wire-secret>
SIGNER_B_ENVELOPE_HPKE_PRIVATE_KEY=hpke-x25519-private-v1:<64-lowercase-hex>
SIGNER_B_PEER_SIGNING_KEY=<32-byte-unpadded-base64url>
SIGNING_WORKER_SERVER_OUTPUT_HPKE_PRIVATE_KEY=hpke-x25519-server-output-private-v1:<64-lowercase-hex>

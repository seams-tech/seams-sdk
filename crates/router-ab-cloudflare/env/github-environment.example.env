# Router A/B GitHub Environment template.
# Generate complete staging or production values with:
# pnpm wallet-core:deploy:env-prepare -- --env <staging|production>
# Copy these names into the matching split GitHub Environments.
# Do not source this file with real secrets.

# GitHub Environment variables.
# wallet-core:deploy:env-prepare generates the target-specific values.
ROUTER_AB_JWT_ISSUER=https://issuer.example
ROUTER_AB_JWT_AUDIENCE=router-ab
ROUTER_AB_JWT_JWKS_URL=https://issuer.example/.well-known/jwks.json
ROUTER_AB_DERIVER_A_ENVELOPE_HPKE_PUBLIC_KEY=x25519:<64-lowercase-hex>
ROUTER_AB_DERIVER_B_ENVELOPE_HPKE_PUBLIC_KEY=x25519:<64-lowercase-hex>
ROUTER_AB_SIGNING_WORKER_SERVER_OUTPUT_HPKE_PUBLIC_KEY=x25519:<64-lowercase-hex>
ROUTER_AB_DERIVER_A_PEER_VERIFYING_KEY_HEX=<64-lowercase-hex>
ROUTER_AB_DERIVER_B_PEER_VERIFYING_KEY_HEX=<64-lowercase-hex>
ROUTER_AB_PROJECT_POLICY_BOOTSTRAP_JSON=<json-object>

# GitHub Environment secrets.
# wallet-core:deploy:env-prepare generates all cryptographic values below.
CLOUDFLARE_API_TOKEN=<worker-deploy-token>
CLOUDFLARE_ACCOUNT_ID=<account-id>
ROUTER_AB_INTERNAL_SERVICE_AUTH_SECRET=router-ab-internal-service-auth-v1:<base64url>
DERIVER_A_ROOT_SHARE_WIRE_SECRET=mpc-prf-root-share-wire-v1:<hex-wire-secret>
DERIVER_A_ENVELOPE_HPKE_PRIVATE_KEY=hpke-x25519-private-v1:<64-lowercase-hex>
DERIVER_A_PEER_SIGNING_KEY=<32-byte-unpadded-base64url>
DERIVER_B_ROOT_SHARE_WIRE_SECRET=mpc-prf-root-share-wire-v1:<hex-wire-secret>
DERIVER_B_ENVELOPE_HPKE_PRIVATE_KEY=hpke-x25519-private-v1:<64-lowercase-hex>
DERIVER_B_PEER_SIGNING_KEY=<32-byte-unpadded-base64url>
SIGNING_WORKER_SERVER_OUTPUT_HPKE_PRIVATE_KEY=hpke-x25519-server-output-private-v1:<64-lowercase-hex>

{
  "name": "router-ab-cloudflare",
  "private": true,
  "type": "module",
  "scripts": {
    "worker-build:install": "cargo install -q worker-build --version 0.8.4",
    "build:combined": "worker-build --release --out-dir build/combined --features strict-worker-entrypoint",
    "build:router": "worker-build --release --out-dir build/router --features strict-worker-router-entrypoint",
    "build:signer-a": "worker-build --release --out-dir build/signer-a --features strict-worker-signer-a-entrypoint",
    "build:signer-b": "worker-build --release --out-dir build/signer-b --features strict-worker-signer-b-entrypoint",
    "build:signing-worker": "worker-build --release --out-dir build/signing-worker --features strict-worker-signing-worker-entrypoint",
    "dry-run:router": "wrangler deploy --dry-run --config wrangler.router.toml --outdir bundled/router --metafile bundled/router/metafile.json",
    "dry-run:signer-a": "wrangler deploy --dry-run --config wrangler.signer-a.toml --outdir bundled/signer-a --metafile bundled/signer-a/metafile.json",
    "dry-run:signer-b": "wrangler deploy --dry-run --config wrangler.signer-b.toml --outdir bundled/signer-b --metafile bundled/signer-b/metafile.json",
    "dry-run:signing-worker": "wrangler deploy --dry-run --config wrangler.signing-worker.toml --outdir bundled/signing-worker --metafile bundled/signing-worker/metafile.json",
    "measure:strict-workers": "node ./scripts/measure-strict-workers.mjs",
    "measure:startup-latencies": "node ./scripts/measure-startup-latencies.mjs",
    "test:wasm-vectors": "wasm-pack test --node . --features strict-worker-router-entrypoint --test wasm_vector_adapters"
  },
  "devDependencies": {
    "wrangler": "^4.40.2"
  }
}

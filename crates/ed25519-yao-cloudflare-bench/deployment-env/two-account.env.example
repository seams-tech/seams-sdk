# Non-secret, benchmark-only deployment boundary.
YAOS_AB_TOPOLOGY=two-account
YAOS_AB_A_ACCOUNT_ID=aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa
YAOS_AB_B_ACCOUNT_ID=bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb
YAOS_AB_A_PROFILE=yaos-deriver-a
YAOS_AB_B_PROFILE=yaos-deriver-b
YAOS_AB_A_SCRIPT_NAME=ed25519-yao-ab-benchmark-a-cross-account
YAOS_AB_B_SCRIPT_NAME=ed25519-yao-ab-benchmark-b-cross-account
YAOS_AB_A_PUBLIC_ENDPOINT=https://yaos-a-benchmark.example.com/benchmark/activation
YAOS_AB_B_HOSTNAME=yaos-b-benchmark.example.com
YAOS_AB_B_HTTPS_ENDPOINT=https://yaos-b-benchmark.example.com/benchmark/activation
YAOS_AB_SAMPLE_COUNT=51
YAOS_AB_REGION_LABEL=tokyo-runner-1
YAOS_AB_DEPLOYMENT_RECEIPT_PATH=/absolute/path/phase9b-two-account-deployment.json

# Required only with the explicit --execute switch.
YAOS_AB_CONFIRM_NON_PRODUCTION=REPLACE_WITH_YES
YAOS_AB_CONFIRM_NO_AUTH_CLAIM=REPLACE_WITH_YES
YAOS_AB_CONFIRM_DELETE_BENCHMARK=REPLACE_WITH_YES

# Analytics window. Read-only Account Analytics tokens stay in the invoking shell.
YAOS_AB_ANALYTICS_START=2026-07-12T00:00:00.000Z
YAOS_AB_ANALYTICS_END=2026-07-12T01:00:00.000Z
# export CLOUDFLARE_ANALYTICS_TOKEN_A=...
# export CLOUDFLARE_ANALYTICS_TOKEN_B=...

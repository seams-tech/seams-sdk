{
  "name": "ed25519-yao-cloudflare-bench",
  "private": true,
  "type": "module",
  "scripts": {
    "worker-build:install": "cargo install -q worker-build --version 0.8.5",
    "build:a": "worker-build --release --out-dir build/deriver-a --features deriver-a",
    "build:a:cross-account": "worker-build --release --out-dir build/deriver-a-cross-account --features deriver-a-cross-account",
    "build:b": "worker-build --release --out-dir build/deriver-b --features deriver-b",
    "build:b:cross-account": "worker-build --release --out-dir build/deriver-b-cross-account --features deriver-b-cross-account",
    "build:fault:fragmentation:a": "worker-build --release --out-dir build/fault-fragmentation-a --features deriver-a,fault-fragmentation",
    "build:fault:fragmentation:b": "worker-build --release --out-dir build/fault-fragmentation-b --features deriver-b,fault-fragmentation",
    "build:fault:request-disconnect:a": "worker-build --release --out-dir build/fault-request-disconnect-a --features deriver-a,fault-request-disconnect-after-base-choices",
    "build:fault:response-disconnect:b": "worker-build --release --out-dir build/fault-response-disconnect-b --features deriver-b,fault-response-disconnect-after-offer",
    "build:fault:trailing:b": "worker-build --release --out-dir build/fault-trailing-b --features deriver-b,fault-trailing-after-terminal",
    "build:fault:timeout:a": "worker-build --release --out-dir build/fault-timeout-a --features deriver-a,fault-short-timeout",
    "build:fault:stall:b": "worker-build --release --out-dir build/fault-stall-b --features deriver-b,fault-stall-after-offer",
    "build:fault:wrong-role:b": "worker-build --release --out-dir build/fault-wrong-role-b --features deriver-b,fault-wrong-role-offer-tag",
    "build:fault:session-mismatch:b": "worker-build --release --out-dir build/fault-session-mismatch-b --features deriver-b,fault-session-mismatch",
    "dry-run:a": "../../packages/console-server-ts/node_modules/.bin/wrangler deploy --dry-run --config wrangler.a.jsonc --outdir bundled/deriver-a",
    "dry-run:a:cross-account": "../../packages/console-server-ts/node_modules/.bin/wrangler deploy --dry-run --config wrangler.a.cross-account.jsonc --outdir bundled/deriver-a-cross-account",
    "dry-run:b": "../../packages/console-server-ts/node_modules/.bin/wrangler deploy --dry-run --config wrangler.b.jsonc --outdir bundled/deriver-b",
    "dry-run:b:cross-account": "../../packages/console-server-ts/node_modules/.bin/wrangler deploy --dry-run --config wrangler.b.cross-account.jsonc --outdir bundled/deriver-b-cross-account",
    "dev:same-account": "WRANGLER_DISABLE_REQUEST_BODY_DRAINING=true ../../packages/console-server-ts/node_modules/.bin/wrangler dev --local -c wrangler.a.jsonc -c wrangler.b.jsonc --port 8787 --persist-to /tmp/ed25519-yao-wrangler-state --show-interactive-dev-session=false",
    "dev:fault:fragmentation": "WRANGLER_DISABLE_REQUEST_BODY_DRAINING=true ../../packages/console-server-ts/node_modules/.bin/wrangler dev --local -c wrangler.fault.fragmentation.a.jsonc -c wrangler.fault.fragmentation.b.jsonc --port 8787 --persist-to /tmp/ed25519-yao-wrangler-fault-fragmentation --show-interactive-dev-session=false",
    "dev:fault:request-disconnect": "WRANGLER_DISABLE_REQUEST_BODY_DRAINING=true ../../packages/console-server-ts/node_modules/.bin/wrangler dev --local -c wrangler.fault.request-disconnect.a.jsonc -c wrangler.b.jsonc --port 8787 --persist-to /tmp/ed25519-yao-wrangler-fault-request-disconnect --show-interactive-dev-session=false",
    "dev:fault:response-disconnect": "WRANGLER_DISABLE_REQUEST_BODY_DRAINING=true ../../packages/console-server-ts/node_modules/.bin/wrangler dev --local -c wrangler.fault.response-disconnect.a.jsonc -c wrangler.fault.response-disconnect.b.jsonc --port 8787 --persist-to /tmp/ed25519-yao-wrangler-fault-response-disconnect --show-interactive-dev-session=false",
    "dev:fault:trailing": "WRANGLER_DISABLE_REQUEST_BODY_DRAINING=true ../../packages/console-server-ts/node_modules/.bin/wrangler dev --local -c wrangler.fault.trailing.a.jsonc -c wrangler.fault.trailing.b.jsonc --port 8787 --persist-to /tmp/ed25519-yao-wrangler-fault-trailing --show-interactive-dev-session=false",
    "dev:fault:timeout": "WRANGLER_DISABLE_REQUEST_BODY_DRAINING=true ../../packages/console-server-ts/node_modules/.bin/wrangler dev --local -c wrangler.fault.timeout.a.jsonc -c wrangler.fault.timeout.b.jsonc --port 8787 --persist-to /tmp/ed25519-yao-wrangler-fault-timeout --show-interactive-dev-session=false",
    "dev:fault:wrong-service": "WRANGLER_DISABLE_REQUEST_BODY_DRAINING=true ../../packages/console-server-ts/node_modules/.bin/wrangler dev --local -c wrangler.fault.wrong-service.a.jsonc -c wrangler.fault.wrong-service.service.jsonc --port 8787 --persist-to /tmp/ed25519-yao-wrangler-fault-wrong-service --show-interactive-dev-session=false",
    "dev:fault:wrong-role": "WRANGLER_DISABLE_REQUEST_BODY_DRAINING=true ../../packages/console-server-ts/node_modules/.bin/wrangler dev --local -c wrangler.fault.wrong-role.a.jsonc -c wrangler.fault.wrong-role.b.jsonc --port 8787 --persist-to /tmp/ed25519-yao-wrangler-fault-wrong-role --show-interactive-dev-session=false",
    "dev:fault:session-mismatch": "WRANGLER_DISABLE_REQUEST_BODY_DRAINING=true ../../packages/console-server-ts/node_modules/.bin/wrangler dev --local -c wrangler.fault.session-mismatch.a.jsonc -c wrangler.fault.session-mismatch.b.jsonc --port 8787 --persist-to /tmp/ed25519-yao-wrangler-fault-session-mismatch --show-interactive-dev-session=false",
    "smoke:fault:success": "node scripts/assert_fault_response.mjs success",
    "smoke:fault:request-disconnect": "node scripts/assert_fault_response.mjs failure YAOS_AB_INBOUND_BODY",
    "smoke:fault:response-disconnect": "node scripts/assert_fault_response.mjs failure YAOS_AB_INBOUND_BODY",
    "smoke:fault:trailing": "node scripts/assert_fault_response.mjs failure YAOS_AB_ENVELOPE",
    "smoke:fault:timeout": "node scripts/assert_fault_response.mjs failure YAOS_AB_TIMEOUT",
    "smoke:fault:wrong-service": "node scripts/assert_fault_response.mjs failure YAOS_AB_PEER_STATUS",
    "smoke:fault:wrong-role": "node scripts/assert_fault_response.mjs failure YAOS_AB_ENVELOPE",
    "smoke:fault:session-mismatch": "node scripts/assert_fault_response.mjs failure YAOS_AB_ROLE",
    "smoke:public-body-rejection": "node scripts/assert_public_body_rejection.mjs",
    "bench:same-account": "node scripts/run_same_account_benchmark.mjs",
    "validate:local-readiness": "node scripts/validate_local_readiness.mjs",
    "deployment:plan": "node scripts/plan_cloudflare_benchmark.mjs",
    "deployment:execute": "node scripts/plan_cloudflare_benchmark.mjs --execute",
    "cleanup:plan": "node scripts/plan_cloudflare_benchmark.mjs --cleanup",
    "cleanup:execute": "node scripts/plan_cloudflare_benchmark.mjs --cleanup --execute",
    "bench:deployed": "node scripts/run_deployed_benchmark.mjs",
    "cold-cohort:assemble": "node scripts/assemble_fresh_version_first_request_series.mjs",
    "analytics:deployed": "node scripts/collect_workers_analytics.mjs",
    "cost:deployed": "node scripts/calculate_deployed_cost.mjs",
    "phase13a:evaluate": "node scripts/evaluate_phase13a_viability.mjs",
    "phase13a:local-preflight": "node scripts/evaluate_phase13a_local_preflight.mjs",
    "audit:isolation": "node scripts/audit_benchmark_isolation.mjs",
    "compute:native": "cargo build --manifest-path ../ed25519-yao/Cargo.toml --release --features passive-benchmark --bin benchmark_phase5_role && node ../ed25519-yao/scripts/collect_phase5_native_compute.mjs",
    "compute:wasm": "node ../ed25519-yao/wasm-bench/scripts/collect_phase5_compute.mjs",
    "test:cost-report-integrity": "node scripts/test_cost_report_integrity.mjs",
    "test:constant-time-codegen": "node ../ed25519-yao/scripts/check_constant_time_codegen.mjs",
    "test:deployment-tooling": "node scripts/test_deployment_tooling.mjs",
    "test:fresh-version-first-request-series": "node scripts/test_fresh_version_first_request_series.mjs",
    "test:rendered-deployment-configs": "node scripts/test_rendered_deployment_configs.mjs",
    "test:local-benchmark-tooling": "node scripts/test_local_benchmark_tooling.mjs",
    "test:phase13a-local-preflight": "node scripts/test_phase13a_local_preflight.mjs",
    "test:isolation": "node scripts/test_benchmark_isolation.mjs"
  },
  "devDependencies": {
    "wrangler": "4.105.0"
  }
}

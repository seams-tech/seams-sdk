alue":[{"Ident":["ArrayLength",0]}]},{"key":{"TraitDecl":17},"value":[{"Ident":["UpdateCore",0]}]},{"key":{"TraitDecl":16},"value":[{"Ident":["Update",0]}]}],"files":[{"name":{"Local":"src/shared/reference.rs"},"crate_name":"ed25519_hss","contents":"use curve25519_dalek::constants::ED25519_BASEPOINT_POINT;\nuse curve25519_dalek::scalar::Scalar;\nuse sha2::{Digest, Sha512};\n\nuse crate::shared::{CanonicalContext, ProtoError, ProtoResult};\n\n#[derive(Debug, Clone, PartialEq, Eq)]\npub struct FExpandInput {\n    pub context: CanonicalContext,\n    pub y_client: [u8; 32],\n    pub y_server: [u8; 32],\n    pub tau_client: [u8; 32],\n    pub tau_server: [u8; 32],\n}\n\n#[derive(Debug, Clone, PartialEq, Eq)]\npub struct FExpandOutput {\n    pub context_binding: [u8; 32],\n    pub m: [u8; 32],\n    pub d: [u8; 32],\n    pub h: [u8; 64],\n    pub a_bytes: [u8; 32],\n    pub a: [u8; 32],\n    pub tau: [u8; 32],\n    pub x_client_base: [u8; 32],\n    pub x_server_base: [u8; 32],\n    pub public_key: [u8; 32],\n}\n\n#[derive(Debug, Clone, PartialEq, Eq)]\npub struct NonlinearExpansionOutput {\n    pub h: [u8; 64],\n    pub a_bytes: [u8; 32],\n    pub a: [u8; 32],\n}\n\n#[derive(Debug, Clone, PartialEq, Eq)]\npub struct OutputShareDerivationOutput {\n    pub tau: [u8; 32],\n    pub x_client_base: [u8; 32],\n    pub x_server_base: [u8; 32],\n}\n\npub fn add_le_bytes_mod_2_256(left: [u8; 32], right: [u8; 32]) -> [u8; 32] {\n    let mut out = [0u8; 32];\n    let mut carry: u16 = 0;\n\n    for idx in 0..32 {\n        let sum = left[idx] as u16 + right[idx] as u16 + carry;\n        out[idx] = (sum & 0xff) as u8;\n        carry = sum >> 8;\n    }\n\n    out\n}\n\npub fn clamp_rfc8032(mut input: [u8; 32]) -> [u8; 32] {\n    input[0] &= 248;\n    input[31] &= 63;\n    input[31] |= 64;\n    input\n}\n\npub fn sha512_one_block(d: [u8; 32]) -> [u8; 64] {\n    let hash = Sha512::digest(d);\n    let mut out = [0u8; 64];\n    out.copy_from_slice(&hash);\n    out\n}\n\npub fn extract_a_bytes_from_hash(h: [u8; 64]) -> [u8; 32] {\n    let mut a_bytes = [0u8; 32];\n    a_bytes.copy_from_slice(&h[..32]);\n    clamp_rfc8032(a_bytes)\n}\n\npub fn reduce_scalar_mod_l(input: [u8; 32]) -> [u8; 32] {\n    Scalar::from_bytes_mod_order(input).to_bytes()\n}\n\npub fn eval_nonlinear_expansion(d: [u8; 32]) -> NonlinearExpansionOutput {\n    let h = sha512_one_block(d);\n    let a_bytes = extract_a_bytes_from_hash(h);\n    let a_scalar = Scalar::from_bytes_mod_order(a_bytes);\n\n    NonlinearExpansionOutput {\n        h,\n        a_bytes,\n        a: a_scalar.to_bytes(),\n    }\n}\n\npub fn eval_f_expand(input: &FExpandInput) -> ProtoResult<FExpandOutput> {\n    let context_binding = input.context.binding_digest()?;\n    let tau_client = parse_canonical_scalar(\"tau_client\", input.tau_client)?;\n    let tau_server = parse_canonical_scalar(\"tau_server\", input.tau_server)?;\n\n    let m = add_le_bytes_mod_2_256(input.y_client, input.y_server);\n    let d = m;\n    let nonlinear = eval_nonlinear_expansion(d);\n    let output_shares = derive_output_shares(\n        nonlinear.a,\n        tau_client.to_bytes(),\n        tau_server.to_bytes()\n    )?;\n    let public_key = public_key_from_scalar_bytes(nonlinear.a)?;\n\n    Ok(FExpandOutput {\n        context_binding,\n        m,\n        d,\n        h: nonlinear.h,\n        a_bytes: nonlinear.a_bytes,\n        a: nonlinear.a,\n        tau: output_shares.tau,\n        x_client_base: output_shares.x_client_base,\n        x_server_base: output_shares.x_server_base,\n        public_key,\n    })\n}\n\npub fn derive_output_shares(\n    a: [u8; 32],\n    tau_client: [u8; 32],\n    tau_server: [u8; 32],\n) -> ProtoResult<OutputShareDerivationOutput> {\n    let a_scalar = parse_canonical_scalar(\"a\", a)?;\n    let tau_client = parse_canonical_scalar(\"tau_client\", tau_client)?;\n    let tau_server = parse_canonical_scalar(\"tau_server\", tau_server)?;\n    let tau = tau_client + tau_server;\n    let x_client_base = a_scalar + tau;\n    let x_server_base = a_scalar + tau + tau;\n\n    Ok(OutputShareDerivationOutput {\n        tau: tau.to_bytes(),\n        x_client_base: x_client_base.to_bytes(),\n        x_server_base: x_server_base.to_bytes(),\n    })\n}\n\npub fn recover_a_from_base_shares(\n    x_client_base: [u8; 32],\n    x_server_base: [u8; 32],\n) -> ProtoResult<[u8; 32]> {\n    let x_client = parse_canonical_scalar(\"x_client_base\", x_client_base)?;\n    let x_server = parse_canonical_scalar(\"x_server_base\", x_server_base)?;\n    Ok((x_client + x_client - x_server).to_bytes())\n}\n\npub fn public_key_from_scalar_bytes(a: [u8; 32]) -> ProtoResult<[u8; 32]> {\n    let scalar = parse_canonical_scalar(\"a\", a)?;\n    Ok((ED25519_BASEPOINT_POINT * scalar).compress().to_bytes())\n}\n\npub fn public_key_from_base_shares(\n    x_client_base: [u8; 32],\n    x_server_base: [u8; 32],\n) -> ProtoResult<[u8; 32]> {\n    let a = recover_a_from_base_shares(x_client_base, x_server_base)?;\n    public_key_from_scalar_bytes(a)\n}\n\nfn parse_canonical_scalar(label: &str, bytes: [u8; 32]) -> ProtoResult<Scalar> {\n    Scalar::from_canonical_bytes(bytes)\n        .into_option()\n        .ok_or_else(|| ProtoError::Decode(format!(\"{label} must be canonical scalar bytes\")))\n}\n"},{"name":{"Local":"src/shared/mod.rs"},"crate_name":"ed25519_hss","contents":"pub mod context;\npub mod error;\npub mod reference;\n\npub use context::CanonicalContext;\npub use error::{ProtoError, ProtoResult};\npub use reference::{\n    add_le_bytes_mod_2_256, clamp_rfc8032, derive_output_shares, eval_f_expand,\n    eval_nonlinear_expansion, extract_a_bytes_from_hash, public_key_from_base_shares,\n    public_key_from_scalar_bytes, recover_a_from_base_shares, reduce_scalar_mod_l,\n    sha512_one_block, FExpandInput, FExpandOutput, NonlinearExpansionOutput,\n    OutputShareDerivationOutput,\n};\n"},{"name":{"Local":"src/lib.rs"},"crate_name":"ed25519_hss","contents":"pub mod artifact;\n#[cfg(not(target_arch = \"wasm32\"))]\npub mod artifact_stub;\n#[cfg(not(target_arch = \"wasm32\"))]\npub mod benchmark;\npub mod candidate;\npub mod client;\npub mod ddh;\n#[cfg(not(target_arch = \"wasm32\"))]\npub mod fixtures;\npub mod protocol;\npub mod runtime;\npub mod server;\npub mod shared;\npub mod wire;\n"},{"name":{"Local":"/cargo/registry/src/index.crates.io-1949cf8c6b5b557f/generic-array-0.14.7/src/lib.rs"},"crate_name":"generic_array","contents":null},{"name":{"Local":"/cargo/registry/src/index.crates.io-1949cf8c6b5b557f/typenum-1.19.0/src/uint.rs"},"crate_name":"typenum","contents":null},{"name":{"Local":"/cargo/registry/src/index.crates.io-1949cf8c6b5b557f/typenum-1.19.0/src/lib.rs"},"crate_name":"typenum","contents":null},{"name":{"Local":"/cargo/registry/src/index.crates.io-1949cf8c6b5b557f/typenum-1.19.0/src/bit.rs"},"crate_name":"typenum","contents":null},{"name":{"Local":"/cargo/registry/src/index.crates.io-1949cf8c6b5b557f/digest-0.10.7/src/digest.rs"},"crate_name":"digest","contents":null},{"name":{"Local":"/cargo/registry/src/index.crates.io-1949cf8c6b5b557f/digest-0.10.7/src/lib.rs"},"crate_name":"digest","contents":null},{"name":{"Local":"/cargo/registry/src/index.crates.io-1949cf8c6b5b557f/digest-0.10.7/src/core_api/wrapper.rs"},"crate_name":"digest","contents":null},{"name":{"Local":"/cargo/registry/src/index.crates.io-1949cf8c6b5b557f/digest-0.10.7/src/core_api.rs"},"crate_name":"digest","contents":null},{"name":{"Local":"/cargo/registry/src/index.crates.io-1949cf8c6b5b557f/digest-0.10.7/src/core_api/ct_variable.rs"},"crate_name":"digest","contents":null},{"name":{"Local":"/cargo/registry/src/index.crates.io-1949cf8c6b5b557f/sha2-0.10.9/src/core_api.rs"},"crate_name":"sha2","contents":null},{"name":{"Local":"/cargo/registry/src/index.crates.io-1949cf8c6b5b557f/sha2-0.10.9/src/lib.rs"},"crate_name":"sha2","contents":null},{"name":{"Local":"/cargo/registry/src/index.crates.io-1949cf8c6b5b557f/typenum-1.19.0/src/type_operators.rs"},"crate_name":"typenum","contents":null},{"nam
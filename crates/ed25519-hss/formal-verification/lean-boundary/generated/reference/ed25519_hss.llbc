l iterator"},{"DocComment":" implementations may choose to resume iteration, and so calling `next()`"},{"DocComment":" again may or may not eventually start returning [`Some(Item)`] again at some"},{"DocComment":" point."},{"DocComment":""},{"DocComment":" [`Some(Item)`]: Some"},{"DocComment":""},{"DocComment":" # Examples"},{"DocComment":""},{"DocComment":" ```"},{"DocComment":" let a = [1, 2, 3];"},{"DocComment":""},{"DocComment":" let mut iter = a.into_iter();"},{"DocComment":""},{"DocComment":" // A call to next() returns the next value..."},{"DocComment":" assert_eq!(Some(1), iter.next());"},{"DocComment":" assert_eq!(Some(2), iter.next());"},{"DocComment":" assert_eq!(Some(3), iter.next());"},{"DocComment":""},{"DocComment":" // ... and then None once it's over."},{"DocComment":" assert_eq!(None, iter.next());"},{"DocComment":""},{"DocComment":" // More calls may or may not return `None`. Here, they always will."},{"DocComment":" assert_eq!(None, iter.next());"},{"DocComment":" assert_eq!(None, iter.next());"},{"DocComment":" ```"}],"inline":null,"rename":null,"public":true},"is_local":false,"opacity":"Foreign","lang_item":"next"},"generics":{"regions":[{"index":0,"name":null,"mutability":"Unknown"}],"types":[{"index":0,"name":"Self"},{"index":1,"name":"Clause0_Item"}],"const_generics":[],"trait_clauses":[{"clause_id":0,"span":{"data":{"file_id":1,"beg":{"line":1,"col":0},"end":{"line":1,"col":0}},"generated_from_span":null},"origin":"WhereClauseOnFn","trait_":{"regions":[],"skip_binder":{"id":6,"generics":{"regions":[],"types":[{"Deduplicated":2215},{"Deduplicated":2216}],"const_generics":[],"trait_refs":[]}}}}],"regions_outlive":[],"types_outlive":[],"trait_type_constraints":[]},"signature":{"is_unsafe":false,"inputs":[{"HashConsedValue":[2323,{"Ref":[{"Var":{"Free":0}},{"Deduplicated":2215},"Mut"]}]}],"output":{"HashConsedValue":[2324,{"Adt":{"id":{"Adt":7},"generics":{"regions":[],"types":[{"Deduplicated":2216}],"const_generics":[],"trait_refs":[]}}}]}},"src":{"TraitDecl":{"trait_ref":{"id":6,"generics":{"regions":[],"types":[{"Deduplicated":2215},{"Deduplicated":2216}],"const_generics":[],"trait_refs":[]}},"item_name":"next","has_default":false}},"is_global_initializer":null,"body":"Opaque"},null,null,null,null,null,null,null,null,null,null,null,null,null,{"def_id":84,"item_meta":{"name":[{"Ident":["core",0]},{"Ident":["iter",0]},{"Ident":["traits",0]},{"Ident":["iterator",0]},{"Ident":["Iterator",0]},{"Ident":["filter",0]}],"span":{"data":{"file_id":15,"beg":{"line":911,"col":4},"end":{"line":914,"col":38}},"generated_from_span":null},"source_text":null,"attr_info":{"attributes":[{"DocComment":" Creates an iterator which uses a closure to determine if an element"},{"DocComment":" should be yielded."},{"DocComment":""},{"DocComment":" Given an element the closure must return `true` or `false`. The returned"},{"DocComment":" iterator will yield only the elements for which the closure returns"},{"DocComment":" `true`."},{"DocComment":""},{"DocComment":" # Examples"},{"DocComment":""},{"DocComment":" Basic usage:"},{"DocComment":""},{"DocComment":" ```"},{"DocComment":" let a = [0i32, 1, 2];"},{"DocComment":""},{"DocComment":" let mut iter = a.into_iter().filter(|x| x.is_positive());"},{"DocComment":""},{"DocComment":" assert_eq!(iter.next(), Some(1));"},{"DocComment":" assert_eq!(iter.next(), Some(2));"},{"DocComment":" assert_eq!(iter.next(), None);"},{"DocComment":" ```"},{"DocComment":""},{"DocComment":" Because the closure passed to `filter()` takes a reference, and many"},{"DocComment":" iterators iterate over references, this leads to a possibly confusing"},{"DocComment":" situation, where the type of the closure is a double reference:"},{"DocComment":""},{"DocComment":" ```"},{"DocComment":" let s = &[0, 1, 2];"},{"DocComment":""},{"DocComment":" let mut iter = s.iter().filter(|x| **x > 1); // needs two *s!"},{"DocComment":""},{"DocComment":" assert_eq!(iter.next(), Some(&2));"},{"DocComment":" assert_eq!(iter.next(), None);"},{"DocComment":" ```"},{"DocComment":""},{"DocComment":" It's common to instead use destructuring on the argument to strip away one:"},{"DocComment":""},{"DocComment":" ```"},{"DocComment":" let s = &[0, 1, 2];"},{"DocComment":""},{"DocComment":" let mut iter = s.iter().filter(|&x| *x > 1); // both & and *"},{"DocComment":""},{"DocComment":" assert_eq!(iter.next(), Some(&2));"},{"DocComment":" assert_eq!(iter.next(), None);"},{"DocComment":" ```"},{"DocComment":""},{"DocComment":" or both:"},{"DocComment":""},{"DocComment":" ```"},{"DocComment":" let s = &[0, 1, 2];"},{"DocComment":""},{"DocComment":" let mut iter = s.iter().filter(|&&x| x > 1); // two &s"},{"DocComment":""},{"DocComment":" assert_eq!(iter.next(), Some(&2));"},{"DocComment":" assert_eq!(iter.next(), None);"},{"DocComment":" ```"},{"DocComment":""},{"DocComment":" of these layers."},{"DocComment":""},{"DocComment":" Note that `iter.filter(f).next()` is equivalent to `iter.find(f)`."},{"Unknown":{"path":"rustc_diagnostic_item","args":"\"iter_filter\""}}],"inline":"Hint","rename":null,"public":true},"is_local":false,"opacity":"Foreign","lang_item":"iter_filter"},"generics":{"regions":[],"types":[{"index":0,"name":"Self"},{"index":1,"name":"P"},{"index":2,"name":"Clause0_Item"}],"const_generics":[],"trait_clauses":[{"clause_id":0,"span":{"data":{"file_id":1,"beg":{"line":1,"col":0},"end":{"line":1,"col":0}},"generated_from_span":null},"origin":"WhereClauseOnFn","trait_":{"regions":[],"skip_binder":{"id":6,"generics":{"regions":[],"types":[{"Deduplicated":2215},{"Deduplicated":2217}],"const_generics":[],"trait_refs":[]}}}},{"clause_id":1,"span":{"data":{"file_id":15,"beg":{"line":914,"col":11},"end":{"line":914,"col":37}},"generated_from_span":null},"origin":"WhereClauseOnFn","trait_":{"regions":[{"index":0,"name":null,"mutability":"Unknown"}],"skip_binder":{"id":35,"generics":{"regions":[],"types":[{"Deduplicated":2216},{"HashConsedValue":[2269,{"Adt":{"id":"Tuple","generics":{"regions":[],"types":[{"HashConsedValue":[2268,{"Ref":[{"Var":{"Bound":[0,0]}},{"Deduplicated":2217},"Shared"]}]}],"const_generics":[],"trait_refs":[]}}}]},{"Deduplicated":24}],"const_generics":[],"trait_refs":[]}}}}],"regions_outlive":[],"types_outlive":[],"trait_type_constraints":[null]},"signature":{"is_unsafe":false,"inputs":[{"Deduplicated":2215},{"Deduplicated":2216}],"output":{"HashConsedValue":[2267,{"Adt":{"id":{"Adt":70},"generics":{"regions":[],"types":[{"Deduplicated":2215},{"Deduplicated":2216}],"const_generics":[],"trait_refs":[]}}}]}},"src":{"TraitDecl":{"trait_ref":{"id":6,"generics":{"regions":[],"types":[{"Deduplicated":2215},{"Deduplicated":2217}],"const_generics":[],"trait_refs":[]}},"item_name":"filter","has_default":true}},"is_global_initializer":null,"body":"Opaque"},null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,{"def_id":100,"item_meta":{"name":[{"Ident":["core",0]},{"Ident":["iter",0]},{"Ident":["traits",0]},{"Ident":["iterator",0]},{"Ident":["Iterator",0]},{"Ident":["collect",0]}],"span":{"data":{"file_id":15,"beg":{"line":2051,"col":4},"end":{"line":2053,"col":20}},"generated_from_span":null},"source_text":null,"attr_info":{"attributes":[{"DocComment":" Transforms an iterator into a collection."},{"DocComment":""},{"DocComment":" `collect()` takes ownership of an iterator and produces whichever"},{"DocComment":" collection type you request. The iterator itself carries no knowledge of"},{"DocComment":" the eventual container; the target collection is chosen entirely by the"},{"DocComment":" type you ask `collect()` to return. This makes `collect()` one of the"},{"DocComment":" more powerful methods in the standard library, and it shows up in a wide"},{"DocComment":" variety of contexts."},{"DocComment":""},{"DocComment":" The most basic pattern in which `collect()` is used is to turn one"},{"DocComment":" collection into another. You take a collection, call [`iter`] on it,"},{"DocComment":" do a bunch of transformations, and then `collect()` at the end."},{"DocComment":""},{"DocComment":" `collect()` can also create instances of types that are not typical"},{"DocComment":" collections. For example, a [`String`] can be built from [`char`]s,"},{"DocComment":" and an iterator of [`Result<T, E>`][`Result`] items can be collected"},{"DocComment":" into `Result<Collection<T>, E>`. See the examples below for more."},{"DocComment":""},{"DocComment":" Because `collect()` is so general, it can cause problems with type"},{"DocComment":" inference. As such, `collect()` is one of the few times you'll see"},{"DocComment":" the syntax affectionately known as the 'turbofish': `::<>`. This"},{"DocComment":" helps the inference algorithm understand specifically which collection"},{"DocComment":" you're trying to collect into."},{"DocComment":""},{"DocComment":" # Examples"},{"DocComment":""},{"DocComment":" Basic usage:"},{"DocComment":""},{"DocComment":" ```"},{"DocComment":" let a = [1, 2, 3];"},{"DocComment":""},{"DocComment":" let doubled: Vec<i32> = a.iter()"},{"DocComment":"                          .map(|x| x * 2)"},{"DocComment":"                          .collect();"},{"DocComment":""},{"DocComment":" assert_eq!(vec![2, 4, 6], doubled);"},{"DocComment":" ```"},{"DocComment":""},{"DocComment":" Note that we needed the `: Vec<i32>` on the left-hand side. This is because"},{"DocComment":" we could collect into, for example, a [`VecDeque<T>`] instead:"},{"DocComment":""},{"DocComment":" [`VecDeque<T>`]: ../../std/collections/struct.VecDeque.html"},{"DocComment":""},{"DocComment":" ```"},{"DocComment":" use std::collections::VecDeque;"},{"DocComment":""},{"DocComment":" let a = [1, 2, 3];"},{"DocComment":""},{"DocComment":" let doubled: VecDeque<i32> = a.iter().map(|x| x * 2).collect();"},{"DocComment":""},{"DocComment":" assert_eq!(2, doubled[0]);"},{"DocComment":" assert_eq!(4, doubled[1]);"},{"DocComment":" assert_eq!(6, doubled[2]);"},{"DocComment":" ```"},{"DocComment":""},{"DocComment":" Using the 'turbofish' instead of annotating `doubled`:"},{"DocComment":""},{"DocComment":" ```"},{"DocComment":" let a = [1, 2, 3];"},{"DocComment":""},{"DocComment":" let doubled = a.iter().map(|x| x * 2).collect::<Vec<i32>>();"},{"DocComment":""},{"DocComment":" assert_eq!(vec![2, 4, 6], doubled);"},{"DocComment":" ```"},{"DocComment":""},{"DocComment":" Because `collect()` only cares about what you're collecting into, you can"},{"DocComment":" still use a partial type hint, `_`, with the turbofish:"},{"DocComment":""},{"DocComment":" ```"},{"DocComment":" let a = [1, 2, 3];"},{"DocComment":""},{"DocComment":" let doubled = a.iter().map(|x| x * 2).collect::<Vec<_>>();"},{"DocComment":""},{"DocComment":" assert_eq!(vec![2, 4, 6], doubled);"},{"DocComment":" ```"},{"DocComment":""},{"DocComment":" Using `collect()` to make a [`String`]:"},{"DocComment":""},{"DocComment":" ```"},{"DocComment":" let chars = ['g', 'd', 'k', 'k', 'n'];"},{"DocComment":""},{"DocComment":" let hello: String = chars.into_iter()"},{"DocComment":"     .map(|x| x as u8)"},{"DocComment":"     .map(|x| (x + 1) as char)"},{"DocComment":"     .collect();"},{"DocComment":""},{"DocComment":" assert_eq!(\"hello\", hello);"},{"DocComment":" ```"},{"DocComment":""},{"DocComment":" If you have a list of [`Result<T, E>`][`Result`]s, you can use `collect()` to"},{"DocComment":" see if any of them failed:"},{"DocComment":""},{"DocComment":" ```"},{"DocComment":" let results = [Ok(1), Err(\"nope\"), Ok(3), Err(\"bad\")];"},{"DocComment":""},{"DocComment":" let result: Result<Vec<_>, &str> = results.into_iter().collect();"},{"DocComment":""},{"DocComment":" // gives us the first error"},{"DocComment":" assert_eq!(Err(\"nope\"), result);"},{"DocComment":""},{"DocComment":" let results = [Ok(1), Ok(3)];"},{"DocComment":""},{"DocComment":" let result: Result<Vec<_>, &str> = results.into_iter().collect();"},{"DocComment":""},{"DocComment":" // gives us the list of answers"},{"DocComment":" assert_eq!(Ok(vec![1, 3
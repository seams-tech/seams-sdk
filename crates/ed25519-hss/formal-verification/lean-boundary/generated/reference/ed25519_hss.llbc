d":2216}],"const_generics":[],"trait_refs":[{"Deduplicated":2450},{"Deduplicated":2431}]}}},{"def_id":140,"item_meta":{"name":[{"Ident":["alloc",0]},{"Ident":["vec",0]},{"Impl":{"Trait":140}}],"span":{"data":{"file_id":53,"beg":{"line":3797,"col":0},"end":{"line":3797,"col":34}},"generated_from_span":null},"source_text":null,"attr_info":{"attributes":[{"DocComment":" Collects an iterator into a Vec, commonly called via [`Iterator::collect()`]"},{"DocComment":""},{"DocComment":" # Allocation behavior"},{"DocComment":""},{"DocComment":" In general `Vec` does not guarantee any particular growth or allocation strategy."},{"DocComment":" That also applies to this trait impl."},{"DocComment":""},{"DocComment":" **Note:** This section covers implementation details and is therefore exempt from"},{"DocComment":" stability guarantees."},{"DocComment":""},{"DocComment":" Vec may use any or none of the following strategies,"},{"DocComment":" depending on the supplied iterator:"},{"DocComment":""},{"DocComment":" * preallocate based on [`Iterator::size_hint()`]"},{"DocComment":"   * and panic if the number of items is outside the provided lower/upper bounds"},{"DocComment":" * use an amortized growth strategy similar to `pushing` one item at a time"},{"DocComment":" * perform the iteration in-place on the original allocation backing the iterator"},{"DocComment":""},{"DocComment":" The last case warrants some attention. It is an optimization that in many cases reduces peak memory"},{"DocComment":" consumption and improves cache locality. But when big, short-lived allocations are created,"},{"DocComment":" only a small fraction of their items get collected, no further use is made of the spare capacity"},{"DocComment":" and the resulting `Vec` is moved into a longer-lived structure, then this can lead to the large"},{"DocComment":" allocations having their lifetimes unnecessarily extended which can result in increased memory"},{"DocComment":" footprint."},{"DocComment":""},{"DocComment":" In cases where this is an issue, the excess capacity can be discarded with [`Vec::shrink_to()`],"},{"DocComment":" [`Vec::shrink_to_fit()`] or by collecting into [`Box<[T]>`][owned slice] instead, which additionally reduces"},{"DocComment":" the size of the long-lived struct."},{"DocComment":""},{"DocComment":" [owned slice]: Box"},{"DocComment":""},{"DocComment":" ```rust"},{"DocComment":" # use std::sync::Mutex;"},{"DocComment":" static LONG_LIVED: Mutex<Vec<Vec<u16>>> = Mutex::new(Vec::new());"},{"DocComment":""},{"DocComment":" for i in 0..10 {"},{"DocComment":"     let big_temporary: Vec<u16> = (0..1024).collect();"},{"DocComment":"     // discard most items"},{"DocComment":"     let mut result: Vec<_> = big_temporary.into_iter().filter(|i| i % 100 == 0).collect();"},{"DocComment":"     // without this a lot of unused capacity might be moved into the global"},{"DocComment":"     result.shrink_to_fit();"},{"DocComment":"     LONG_LIVED.lock().unwrap().push(result);"},{"DocComment":" }"},{"DocComment":" ```"}],"inline":null,"rename":null,"public":false},"is_local":false,"opacity":"Foreign","lang_item":null},"impl_trait":{"id":36,"generics":{"regions":[],"types":[{"Deduplicated":2257},{"Deduplicated":2215}],"const_generics":[],"trait_refs":[]}},"generics":{"regions":[],"types":[{"index":0,"name":"T"}],"const_generics":[],"trait_clauses":[],"regions_outlive":[],"types_outlive":[],"trait_type_constraints":[]},"implied_trait_refs":[],"consts":[],"types":[],"methods":[["from_iter",{"params":{"regions":[],"types":[{"index":0,"name":"I"},{"index":1,"name":"Clause0_IntoIter"}],"const_generics":[],"trait_clauses":[{"clause_id":0,"span":{"data":{"file_id":53,"beg":{"line":3799,"col":20},"end":{"line":3799,"col":42}},"generated_from_span":null},"origin":"WhereClauseOnFn","trait_":{"regions":[],"skip_binder":{"id":34,"generics":{"regions":[],"types":[{"Deduplicated":8},{"Deduplicated":2215},{"Deduplicated":11}],"const_generics":[],"trait_refs":[]}}}}],"regions_outliv
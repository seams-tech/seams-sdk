hichever"},{"DocComment":" collection type you request. The iterator itself carries no knowledge of"},{"DocComment":" the eventual container; the target collection is chosen entirely by the"},{"DocComment":" type you ask `collect()` to return. This makes `collect()` one of the"},{"DocComment":" more powerful methods in the standard library, and it shows up in a wide"},{"DocComment":" variety of contexts."},{"DocComment":""},{"DocComment":" The most basic pattern in which `collect()` is used is to turn one"},{"DocComment":" collection into another. You take a collection, call [`iter`] on it,"},{"DocComment":" do a bunch of transformations, and then `collect()` at the end."},{"DocComment":""},{"DocComment":" `collect()` can also create instances of types that are not typical"},{"DocComment":" collections. For example, a [`String`] can be built from [`char`]s,"},{"DocComment":" and an iterator of [`Result<T, E>`][`Result`] items can be collected"},{"DocComment":" into `Result<Collection<T>, E>`. See the examples below for more."},{"DocComment":""},{"DocComment":" Because `collect()` is so general, it can cause problems with type"},{"DocComment":" inference. As such, `collect()` is one of the few times you'll see"},{"DocComment":" the syntax affectionately known as the 'turbofish': `::<>`. This"},{"DocComment":" helps the inference algorithm understand specifically which collection"},{"DocComment":" you're trying to collect into."},{"DocComment":""},{"DocComment":" # Examples"},{"DocComment":""},{"DocComment":" Basic usage:"},{"DocComment":""},{"DocComment":" ```"},{"DocComment":" let a = [1, 2, 3];"},{"DocComment":""},{"DocComment":" let doubled: Vec<i32> = a.iter()"},{"DocComment":"                          .map(|x| x * 2)"},{"DocComment":"                          .collect();"},{"DocComment":""},{"DocComment":" assert_eq!(vec![2, 4, 6], doubled);"},{"DocComment":" ```"},{"DocComment":""},{"DocComment":" Note that we needed the `: Vec<i32>` on the left-hand side. This is because"},{"DocComment":" we could collect into, for example, a [`VecDeque<T>`] instead:"},{"DocComment":""},{"DocComment":" [`VecDeque<T>`]: ../../std/collections/struct.VecDeque.html"},{"DocComment":""},{"DocComment":" ```"},{"DocComment":" use std::collections::VecDeque;"},{"DocComment":""},{"DocComment":" let a = [1, 2, 3];"},{"DocComment":""},{"DocComment":" let doubled: VecDeque<i32> = a.iter().map(|x| x * 2).collect();"},{"DocComment":""},{"DocComment":" assert_eq!(2, doubled[0]);"},{"DocComment":" assert_eq!(4, doubled[1]);"},{"DocComment":" assert_eq!(6, doubled[2]);"},{"DocComment":" ```"},{"DocComment":""},{"DocComment":" Using the 'turbofish' instead of annotating `doubled`:"},{"DocComment":""},{"DocComment":" ```"},{"DocComment":" let a = [1, 2, 3];"},{"DocComment":""},{"DocComment":" let doubled = a.iter().map(|x| x * 2).collect::<Vec<i32>>();"},{"DocComment":""},{"DocComment":" assert_eq!(vec![2, 4, 6], doubled);"},{"DocComment":" ```"},{"DocComment":""},{"DocComment":" Because `collect()` only cares about what you're collecting into, you can"},{"DocComment":" still use a partial type hint, `_`, with the turbofish:"},{"DocComment":""},{"DocComment":" ```"},{"DocComment":" let a = [1, 2, 3];"},{"DocComment":""},{"DocComment":" let doubled = a.iter().map(|x| x * 2).collect::<Vec<_>>();"},{"DocComment":""},{"DocComment":" assert_eq!(vec![2, 4, 6], doubled);"},{"DocComment":" ```"},{"DocComment":""},{"DocComment":" Using `collect()` to make a [`String`]:"},{"DocComment":""},{"DocComment":" ```"},{"DocComment":" let chars = ['g', 'd', 'k', 'k', 'n'];"},{"DocComment":""},{"DocComment":" let hello: String = chars.into_iter()"},{"DocComment":"     .map(|x| x as u8)"},{"DocComment":"     .map(|x| (x + 1) as char)"},{"DocComment":"     .collect();"},{"DocComment":""},{"DocComment":" assert_eq!(\"hello\", hello);"},{"DocComment":" ```"},{"DocComment":""},{"DocComment":" If you have a list of [`Result<T, E>`][`Result`]s, you can use `collect()` to"},{"DocComment":" see if any of them failed:"},{"DocComment":""},{"DocComment":" ```"},{"DocComment":" let results = [Ok(1), Err(\"nope\"), Ok(3), Err(\"bad\")];"},{"DocComment":""},{"DocComment":" let result: Result<Vec<_>, &str> = results.into_iter().collect();"},{"DocComment":""},{"DocComment":" // gives us the first error"},{"DocComment":" assert_eq!(Err(\"nope\"), result);"},{"DocComment":""},{"DocComment":" let results = [Ok(1), Ok(3)];"},{"DocComment":""},{"DocComment":" let result: Result<Vec<_>, &str> = results.into_iter().collect();"},{"DocComment":""},{"DocComment":" // gives us the list of answers"},{"DocComment":" assert_eq!(Ok(vec![1, 3]), result);"},{"DocComment":" ```"},{"DocComment":""},{"DocComment":" [`iter`]: Iterator::next"},{"DocComment":" [`String`]: ../../std/string/struct.String.html"},{"DocComment":" [`char`]: type@char"},{"Unknown":{"path":"rustc_diagnostic_item","args":"\"iterator_collect_fn\""}}],"inline":"Hint","rename":null,"public":true},"is_local":false,"opacity":"Foreign","lang_item":"iterator_collect_fn"},"generics":{"regions":[],"types":[{"index":0,"name":"A"},{"index":1,"name":"B"}],"const_generics":[],"trait_clauses":[{"clause_id":0,"span":{"data":{"file_id":16,"beg":{"line":852,"col":8},"end":{"line":852,"col":12}},"generated_from_span":null},"origin":"WhereClauseOnImpl","trait_":{"regions":[],"skip_binder":{"id":7,"generics":{"regions":[],"types":[{"Deduplicated":2215}],"const_generics":[],"trait_refs":[]}}}},{"clause_id":1,"span":{"data":{"file_id":15,"beg":{"line":2051,"col":18},"end":{"line":2051,"col":42}},"generated_from_span":null},"origin":"WhereClauseOnFn","trait_":{"regions":[],"skip_binder":{"id":36,"generics":{"regions":[],"types":[{"Deduplicated":2216},{"Deduplicated":2215}],"const_generics":[],"trait_refs":[]}}}}],"regions_outlive":[],"types_outlive":[],"trait_type_constraints":[]},"signature":{"is_unsafe":false,"inputs":[{"Deduplicated":2231}],"output":{"Deduplicated":2216}},"src":{"TraitImpl":{"impl_ref":{"id":21,"generics
 not [`char`]s or graphemes. In other words,"},{"DocComment":" it might not be what a human considers the length of the string."},{"DocComment":""},{"DocComment":" [`char`]: prim@char"},{"DocComment":""},{"DocComment":" # Examples"},{"DocComment":""},{"DocComment":" ```"},{"DocComment":" let len = \"foo\".len();"},{"DocComment":" assert_eq!(3, len);"},{"DocComment":""},{"DocComment":" assert_eq!(\"ƒoo\".len(), 4); // fancy f!"},{"DocComment":" assert_eq!(\"ƒoo\".chars().count(), 3);"},{"DocComment":" ```"},{"Unknown":{"path":"rustc_diagnostic_item","args":"\"str_len\""}}],"inline":"Hint","rename":null,"public":true},"is_local":false,"opacity":"Foreign","lang_item":"str_len"},"generics":{"regions":[{"index":0,"name":null,"mutability":"Unknown"}],"types":[],"const_generics":[],"trait_clauses":[],"regions_outlive":[],"types_outlive":[],"trait_type_constraints":[]},"signature":{"is_unsafe":false,"inputs":[{"Deduplicated":2272}],"output":{"Deduplicated":3}},"src":"TopLevel","is_global_initializer":null,"body":"Opaque"},{"def_id":493,"item_meta":{"name":[{"Ident":["core",0]},{"Ident":["str",0]},{"Impl":{"Ty":{"params":{"regions":[],"types":[],"const_generics":[],"trait_clauses":[],"regions_outlive":[],"types_outlive":[],"trait_type_constraints":[]},"skip_binder":{"Deduplicated":84},"kind":"InherentImplBlock"}}},{"Ident":["as_bytes",0]}],"span":{"data":{"file_id":76,"beg":{"line":486,"col":4},"end":{"line":486,"col":41}},"generated_from_span":null},"source_text":null,"attr_info":{"attributes":[{"DocComment":" Converts a string slice to a byte slice. To convert the byte slice back"},{"DocComment":" into a string slice, use the [`from_utf8`] function."},{"DocComment":""},{"DocComment":" # Examples"},{"DocComment":""},{"DocComment":" ```"},{"DocComment":" let bytes = \"bors\".as_bytes();"},{"DocComment":" assert_eq!(b\"bors\", bytes);"},{"DocComment":" ```"}],"inline":"Always","rename":null,"public":true},"is_local":false,"opacity":"Foreign","lang_item":null},"generics":{"regions":[{"index":0,"name":null,"mutability":"Unknown"}],"types":[],"const_generics":[],"trait_clauses":[],"regions_outlive":[],"types_outlive":[],"trait_type_constraints":[]},"signature":{"is_unsafe":false,"inputs":[{"Deduplicated":2272}],"output":{"HashConsedValue":[2401,{"Ref":[{"Var":{"Free":0}},{"Deduplicated":39},"Shared"]}]}},"src":"TopLevel","is_global_initializer":null,"body":"Opaque"},null,null,null,null,null,null,null,null,null,null,null,null,null,null,{"def_id":508,"item_meta":{"name":[{"Ident":["alloc",0]},{"Ident":["vec",0]},{"Ident":["into_iter",0]},{"Impl":{"Trait":113}},{"Ident":["filter",0]}],"span":{"data":{"file_id":66,"beg":{"line":210,"col":0},"end":{"line":210,"col":49}},"generated_from_span":null},"source_text":null,"attr_info":{"attributes":[{"DocComment":" Creates an iterator which uses a closure to determine if an element"},{"DocComment":" should be yielded."},{"DocComment":""},{"DocComment":" Given an element the closure must return `true` or `false`. The returned"},{"DocComment":" iterator will yield only the elements for which the closure returns"},{"DocComment":" `true`."},{"DocComment":""},{"DocComment":" # Examples"},{"DocComment":""},{"DocComment":" Basic usage:"},{"DocComment":""},{"DocComment":" ```"},{"DocComment":" let a = [0i32, 1, 2];"},{"DocComment":""},{"DocComment":" let mut iter = a.into_iter().filter(|x| x.is_positive());"},{"DocComment":""},{"DocComment":" assert_eq!(iter.next(), Some(1));"},{"DocComment":" assert_eq!(iter.next(), Some(2));"},{"DocComment":" assert_eq!(iter.next(), None);"},{"DocComment":" ```"},{"DocComment":""},{"DocComment":" Because the closure passed to `filter()` takes a reference, and many"},{"DocComment":" iterators iterate over references, this leads to a possibly confusing"},{"DocComment":" situation, where the type of the closure is a double reference:"},{"DocComment":""},{"DocComment":" ```"},{"DocComment":" let s = &[0, 1, 2];"},{"DocComment":""},{"DocComment":" let mut iter = s.iter().filter(|x| **x > 1); // needs two *s!"},{"DocComment":""},{"DocComment":" assert_eq!(iter.next(), Some(&2));"},{"DocComment":" assert_eq!(iter.next(), None);"},{"DocComment":" ```"},{"DocComment":""},{"DocComment":" It's common to instead use destructuring on the argument to strip away one:"},{"DocComment":""},{"DocComment":" ```"},{"DocComment":" let s = &[0, 1, 2];"},{"DocComment":""},{"DocComment":" let mut iter = s.iter().filter(|&x| *x > 1); // both & and *"},{"DocComment":""},{"DocComment":" assert_eq!(iter.next(), Some(&2));"},{"DocComment":" assert_eq!(iter.next(), None);"},{"DocComment":" ```"},{"DocComment":""},{"DocComment":" or both:"},{"DocComment":""},{"DocComment":" ```"},{"DocComment":" let s = &[0, 1, 2];"},{"DocComment":""},{"DocComment":" let mut iter = s.iter().filter(|&&x| x > 1); // two &s"},{"DocComment":""},{"DocComment":" assert_eq!(iter.next(), Some(&2));"},{"DocComment":" assert_eq!(iter.next(), None);"},{"DocComment":" ```"},{"DocComment":""},{"DocComment":" of these layers."},{"DocComment":""},{"DocComment":" Note that `iter.filter(f).next()` is equivalent to `iter.find(f)`."},{"Unknown":{"path":"rustc_diagnostic_item","args":"\"iter_filter\""}}],"inline":"Hint","rename":null,"public":true},"is_local":false,"opacity":"Foreign","lang_item":"iter_filter"},"generics":{"regions":[],"types":[{"index":0,"name":"T"},{"index":1,"name":"A"},{"index":2,"name":"P"}],"const_generics":[],"trait_clauses":[null,{"clause_id":1,"span":{"data":{"file_id":15,"beg":{"line":914,"col":11},"end":{"line":914,"col":37}},"generated_from_span":null},"origin":"WhereClauseOnFn","trait_":{"regions":[{"index":0,"name":null,"mutability":"Unknown"}],"skip_binder":{"id":35,"generics":{"regions":[],"types":[{"Deduplicated":2217},{"Deduplicated":2233},{"Deduplicated":24}],"const_generics":[],"trait_refs":[]}}}}],"regions_outlive":[],"types_outlive":[],"trait_type_constraints":[null]},"signature":{"is_unsafe":false,"inputs":[{"Deduplicated":2258},{"Deduplicated":2217}],"output":{"HashConsedValue":[2402,{"Adt":{"id":{"Adt":70},"generics":{"regions":[],"types":[{"Deduplicated":2258},{"Deduplicated":2217}],"const_generics":[],"trait_refs":[]}}}]}},"src":{"TraitImpl":{"impl_ref":{"id":113,"generics":{"regions":[],"types":[{"Deduplicated":2215},{"Deduplicated":2216}],"const_generics":[],"trait_refs":[null]}},"trait_ref":{"id":6,"generics":{"regions":[],"types":[{"Deduplicated":2258},{"Deduplicated":2215}],"const_generics":[],"trait_refs":[]}},"item_name":"filter","reuses_default":true}},"is_global_initializer":null,"body":"Opaque"},null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,{"def_id":524,"item_meta":{"name":[{"Ident":["alloc",0]},{"Ident":["vec",0]},{"Ident":["into_iter",0]},{"Impl":{"Trait":113}},{"Ident":["collect",0]}],"span":{"data":{"file_id":66,"beg":{"line":210,"col":0},"end":{"line":210,"col":49}},"generated_from_span":null},"source_text":null,"attr_info":{"attributes":[{"DocComment":" Transforms an iterator into a collection."},{"DocComment":""},{"DocComment":" `collect()` takes ownership of an iterator and produces whichever"},{"DocComment":" collection type you request. The iterator itself carries no knowledge of"},{"DocComment":" the eventual container; the target collection is chosen entirely by the"},{"DocComment":" type you ask `collect()` to return. This makes `collect()` one of the"},{"DocComment":" more powerful methods in the standard library, and it shows up in a wide"},{"DocComment":" variety of contexts."},{"DocComment":""},{"DocComment":" The most basic pattern in which `collect()` is used is to turn one"},{"DocComment":" collection into another. You take a collection, call [`iter`] on it,"},{"DocComment":" do a bunch of transformations, and then `collect()` at the end."},{"DocComment":""},{"DocComment":" `collect()` can also create instances of types that are not typical"},{"DocComment":" collections. For example, a [`String`] can be built from [`char`]s,"},{"DocComment":" and an iterator of [`Result<T, E>`][`Result`] items can be collected"},{"DocComment":" into `Result<Collection<T>, E>`. See the examples below for more."},{"DocComment":""},{"DocComment":" Because `collect()` is so general, it can cause problems with type"},{"DocComment":" inference. As such, `collect()` is one of the few times you'll see"},{"DocComment":" the syntax affectionately known as the 'turbofish': `::<>`. This"},{"DocComment":" helps the inference algorithm understand specifically which collection"},{"DocComment":" you're trying to collect into."},{"DocComment":""},{"DocComment":" # Examples"},{"DocComment":""},{"DocComment":" Basic usage:"},{"DocComment":""},{"DocComment":" ```"},{"DocComment":" let a = [1, 2, 3];"},{"DocComment":""},{"DocComment":" let doubled: Vec<i32> = a.iter()"},{"DocComment":"                          .map(|x| x * 2)"},{"DocComment":"                          .collect();"},{"DocComment":""},{"DocComment":" assert_eq!(vec![2, 4, 6], doubled);"},{"DocComment":" ```"},{"DocComment":""},{"DocComment":" Note that we needed the `: Vec<i32>` on the left-hand side. This is because"},{"DocComment":" we could collect into, for example, a [`VecDeque<T>`] instead:"},{"DocComment":""},{"DocComment":" [`VecDeque<T>`]: ../../std/collections/struct.VecDeque.html"},{"DocComment":""},{"DocComment":" ```"},{"DocComment":" use std::collections::VecDeque;"},{"DocComment":""},{"DocComment":" let a = [1, 2, 3];"},{"DocComment":""},{"DocComment":" let doubled: VecDeque<i32> = a.iter().map(|x| x * 2).collect();"},{"DocComment":""},{"DocComment":" assert_eq!(2, doubled[0]);"},{"DocComment":" assert_eq!(4, doubled[1]);"},{"DocComment":" assert_eq!(6, doubled[2]);"},{"DocComment":" ```"},{"DocComment":""},{"DocComment":" Using the 'turbofish' instead of annotating `doubled`:"},{"DocComment":""},{"DocComment":" ```"},{"DocComment":" let a = [1, 2, 3];"},{"DocComment":""},{"DocComment":" let doubled = a.iter().map(|x| x * 2).collect::<Vec<i32>>();"},{"DocComment":""},{"DocComment":" assert_eq!(vec![2, 4, 6], doubled);"},{"DocComment":" ```"},{"DocComment":""},{"DocComment":" Because `collect()` only cares about what you're collecting into, you can"},{"DocComment":" still use a partial type hint, `_`, with the turbofish:"},{"DocComment":""},{"DocComment":" ```"},{"DocComment":" let a = [1, 2, 3];"},{"DocComment":""},{"DocComment":" let doubled = a.iter().map(|x| x * 2).collect::<Vec<_>>();"},{"DocComment":""},{"DocComment":" assert_eq!(vec![2, 4, 6], doubled);"},{"DocComment":" ```"},{"DocComment":""},{"DocComment":" Using `collect()` to make a [`String`]:"},{"DocComment":""},{"DocComment":" ```"},{"DocComment":" let chars = ['g', 'd', 'k', 'k', 'n'];"},{"DocComment":""},{"DocComment":" let hello: String = chars.into_iter()"},{"DocComment":"     .map(|x| x as u8)"},{"DocComment":"     .map(|x| (x + 1) as char)"},{"DocComment":"     .collect();"},{"DocComment":""},{"DocComment":" assert_eq!(\"hello\", hello);"},{"DocComment":" ```"},{"DocComment":""},{"DocComment":" If you have a list of [`Result<T, E>`][`Result`]s, you can use `collect()` to"},{"DocComment":" see if any of them failed:"},{"DocComment":""},{"DocComment":" ```"},{"DocComment":" let results = [Ok(1), Err(\"nope\"), Ok(3), Err(\"bad\")];"},{"DocComment":""},{"DocComment":" let result: Result<Vec<_>, &str> = results.into_iter().collect();"},{"DocComment":""},{"DocComment":" // gives us the first error"},{"DocComment":" assert_eq!(Err(\"nope\"), result);"},{"DocComment":""},{"DocComment":" let results = [Ok(1), Ok(3)];"},{"DocComment":""},{"DocComment":" let result: Result<Vec<_>, &str> = results.into_iter().collect();"},{"DocComment":""},{"DocComment":" // gives us the list of answers"},{"DocComment":" assert_eq!(Ok(vec![1, 3]), result);"},{"DocComment":" ```"},{"DocComment":""},{"DocComment":" [`iter`]: Iterator::next"},{"DocComment":" [`String`]: ../../std/string/struct.String.html"},{"DocComment":" [`char`]: type@char"},{"Unknown":{"path":"rustc_diagnostic_item","args":"\"iterator_collect_fn\""}}],"inline":"Hint","rename":null,"public":true},"is_local":false,"opacity":"Foreign","lang_item":"iterator_collect_fn"},"generics":{"regions":[],"types":[{"index":0,"name":"T"},{"index":1,"name":"A"},{"index":2,"name":"B"}],"const_generics":[],"trait_clauses":[null,{"clause_id":1,"span":{"data":{"file_id":15,"beg":{"line":2051,"col":18},"end":{"line":2051,"col":42}},"generated_from_span":null},"origin":"WhereClauseOnFn","trait_":{"regions":[],"skip_binder":{"id":36,"generics":{"regions":[],"types":[{"Deduplicated":2217},{"Deduplicated":2215}],"const_generics":[],"trait_refs":[]}}}}],"regions_outlive":[],"types_outlive":[],"trait_type_constraints":[]},"signature":{"is_unsafe":false,"inputs":[{"Deduplicated":2258}],"output":{"Deduplicated":2217}},"src":{"TraitImpl":{"impl_ref":{"id":113,"generics":{"regions":[],"types":[{"Deduplicated":2215},{"Deduplicated":2216}],"const_generics":[],"trait_refs":[null]}},"trait_ref":{"id":6,"generics":{"regions":[],"types":[{"Deduplicated":2258},{"Deduplicated":2215}],"const_generics":[],"trait_refs":[]}},"item_name":"collect","reuses_default":true}},"is_global_initializer":null,"body":"Opaque"},null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,{"def_id":550,"item_meta":{"name":[{"Ident":["alloc",0]},{"Ident":["vec",0]},{"Ident":["into_iter",0]},{"Impl":{"Trait":113}},{"Ident":["copied",0]}],"span":{"data":{"file_id":66,"beg":{"line":210,"col":0},"end":{"line":210,"col":49}},"generated_from_span":null},"source_text":null,"attr_info":{"attributes":[{"DocComment":" Creates an iterator which copies all of its elements."},{"DocComment":""},{"DocComment":" This is useful when you have an iterator over `&T`, but you need an"},{"DocComment":" iterator over `T`."},{"DocComment":""},{"DocComment":" # Examples"},{"DocComment":""},{"DocComment":" ```"},{"DocComment":" let a = [1, 2, 3];"},{"DocComment":""},{"DocComment":" let v_copied: Vec<_> = a.iter(
":""},{"DocComment":" [`format_args!`]: core::format_args"},{"DocComment":" [`format!`]: crate::format"}],"inline":"Hint","rename":null,"public":true},"is_local":false,"opacity":"Foreign","lang_item":null},"generics":{"regions":[{"index":0,"name":null,"mutability":"Unknown"}],"types":[],"const_generics":[],"trait_clauses":[],"regions_outlive":[],"types_outlive":[],"trait_type_constraints":[]},"signature":{"is_unsafe":false,"inputs":[{"Deduplicated":2410}],"output":{"Deduplicated":132}},"src":"TopLevel","is_global_initializer":null,"body":"Opaque"},{"def_id":579,"item_meta":{"name":[{"Ident":["core",0]},{"Ident":["hint",0]},{"Ident":["must_use",0]}],"span":{"data":{"file_id":80,"beg":{"line":613,"col":0},"end":{"line":613,"col":39}},"generated_from_span":null},"source_text":null,"attr_info":{"attributes":[{"DocComment":" An identity function that causes an `unused_must_use` warning to be"},{"DocComment":" triggered if the given value is not used (returned, stored in a variable,"},{"DocComment":" etc) by the caller."},{"DocComment":""},{"DocComment":" This is primarily intended for use in macro-generated code, in which a"},{"DocComment":" [`#[must_use]` attribute][must_use] either on a type or a function would not"},{"DocComment":" be convenient."},{"DocComment":""},{"DocComment":" [must_use]: https://doc.rust-lang.org/reference/attributes/diagnostics.html#the-must_use-attribute"},{"DocComment":""},{"DocComment":" # Example"},{"DocComment":""},{"DocComment":" ```"},{"DocComment":" #![feature(hint_must_use)]"},{"DocComment":""},{"DocComment":" use core::fmt;"},{"DocComment":""},{"DocComment":" pub struct Error(/* ... */);"},{"DocComment":""},{"DocComment":" #[macro_export]"},{"DocComment":" macro_rules! make_error {"},{"DocComment":"     ($($args:expr),*) => {"},{"DocComment":"         core::hint::must_use({"},{"DocComment":"             let error = $crate::make_error(core::format_args!($($args),*));"},{"DocComment":"             error"},{"DocComment":"         })"},{"DocComment":"     };"},{"DocComment":" }"},{"DocComment":""},{"DocComment":" // Implementation detail of make_error! macro."},{"DocComment":" #[doc(hidden)]"},{"DocComment":" pub fn make_error(args: fmt::Arguments<'_>) -> Error {"},{"DocComment":"     Error(/* ... */)"},{"DocComment":" }"},{"DocComment":""},{"DocComment":" fn demo() -> Option<Error> {"},{"DocComment":"     if true {"},{"DocComment":"         // Oops, meant to write `return Some(make_error!(\"...\"));`"},{"DocComment":"         Some(make_error!(\"...\"));"},{"DocComment":"     }"},{"DocComment":"     None"},{"DocComment":" }"},{"DocComment":" #"},{"DocComment":" # // Make rustdoc not wrap the whole snippet in fn main, so that $crate::make_error works"},{"DocComment":" # fn main() {}"},{"DocComment":" ```"},{"DocComment":""},{"DocComment":" In the above example, we'd like an `unused_must_use` lint to apply to the"},{"DocComment":" value created by `make_error!`. However, neither `#[must_use]` on a struct"},{"DocComment":" nor `#[must_use]` on a function is appropriate here, so the macro expands"},{"DocComment":" using `core::hint::must_use` instead."},{"DocComment":""},{"DocComment":" - We wouldn't want `#[must_use]` on the `struct Error` because that would"},{"DocComment":"   make the following unproblematic code trigger a warning:"},{"DocComment":""},{"DocComment":"   ```"},{"DocComment":"   # struct Error;"},{"DocComment":"   #"},{"DocComment":"   fn f(arg: &str) -> Result<(), Error>"},{"DocComment":"   # { Ok(()) }"},{"DocComment":""},{"DocComment":"   #[test]"},{"DocComment":"   fn t() {"},{"DocComment":"       // Assert that `f` returns error if passed an empty string."},{"DocComment":"       // A value of type `Error` is unused here but that's not a problem."},{"DocComment":"       f(\"\").unwrap_err();"},{"DocComment":"   }"},{"DocComment":"   ```"},{"DocComment":""},{"DocComment":" - Using `#[must_use]` on `fn make_error` can't help because the return value"},{"DocComment":"   *is* used, as the right-hand side of a `let` statement. The `let`"},{"DocComment":"   statement looks useless but is in fact necessary for ensuring that"},{"DocComment":"   temporaries within the `format_args` expansion are not kept alive past the"},{"DocComment":"   creation of the `Error`, as keeping them alive past that point can cause"},{"DocComment":"   autotrait issues in async code:"},{"DocComment":""},{"DocComment":"   ```"},{"DocComment":"   # #![feature(hint_must_use)]"},{"DocComment":"   #"},{"DocComment":"   # struct Error;"},{"DocComment":"   #"},{"DocComment":"   # macro_rules! make_error {"},{"DocComment":"   #     ($($args:expr),*) => {"},{"DocComment":"   #         core::hint::must_use({"},{"DocComment":"   #             // If `let` isn't used, then `f()` produces a non-Send future."},{"DocComment":"   #             let error = make_error(core::format_args!($($args),*));"},{"DocComment":"   #             error"},{"DocComment":"   #         })"},{"DocComment":"   #     };"},{"DocComment":"   # }"},{"DocComment":"   #"},{"DocComment":"   # fn make_error(args: core::fmt::Arguments<'_>) -> Error {"},{"DocComment":"   #     Error"},{"DocComment":"   # }"},{"DocComment":"   #"},{"DocComment":"   async fn f() {"},{"DocComment":"       // Using `let` inside the make_error expansion causes temporaries like"},{"DocComment":"       // `unsync()` to drop at the semicolon of that `let` statement, which"},{"DocComment":"       // is prior to the await point. They would otherwise stay around until"},{"DocComment":"       // the semicolon on *this* statement, which is after the await point,"},{"DocComment":"       // and the enclosing Future would not implement Send."},{"DocComment":"       log(make_error!(\"look: {:p}\", unsync())).await;"},{"DocComment":"   }"},{"DocComment":""},{"DocComment":"   async fn log(error: Error) {/* ... */}"},{"DocComment":""},{"DocComment":"   // Returns something without a Sync impl."},{"DocComment":"   fn unsync() -> *const () {"},{"DocComment":"       0 as *const ()"},{"DocComment":"   }"},{"DocComment":"   #"},{"DocComment":"   # fn test() {"},{"DocComment":"   #     fn assert_send(_: impl Send) {}"},{"DocComment":"   #     assert_send(f());"},{"DocComment":"   # }"},{"DocComment":"   ```"}],"inline":"Always","rename":null,"public":true},"is_local":false,"opacity":"Foreign","lang_item":null},"generics":{"regions":[],"types":[{"index":0,"name":"T"}],"const_generics":[],"trait_clauses":[],"regions_outlive":[],"types_outlive":[],"trait_type_constraints":[]},"signature":{"is_unsafe":false,"inputs":[{"Deduplicated":2215}],"output":{"Deduplicated":2215}},"src":"TopLevel","is_global_initializer":null,"body":"Opaque"},null,null,null,{"def_id":583,"item_meta":{"name":[{"Ident":["core",0]},{"Ident":["clone",0]},{"Ident":["impls",0]},{"Impl":{"Trait":118}},{"Ident":["clone",0]}],"span":{"data":{"file_id":6,"beg":{"line":614,"col":20},"end":{"line":614,"col":43}},"generated_from_span":null},"source_text":null,"attr_info":{"attributes":[],"inline":"Always","rename":null,"public":true},"is_local":false,"opacity":"Foreign","lang_item":null},"generics":{"regions":[{"index":0,"name":null,"mutability":"Unknown"}],"types":[],"const_generics":[],"trait_clauses":[],"regions_outlive":[],"types_outlive":[],"trait_type_constraints":[]},"signature":{"is_unsafe":false,"inputs":[{"HashConsedValue":[2411,{"Ref":[{"Var":{"Free":0}},{"Deduplicated":17},"Shared"]}]}],"output":{"Deduplicated":17}},"src":{"TraitImpl":{"impl_ref":{"id":118,"generics":{"regions":[],"types":[],"const_generics":[],"trait_refs":[]}},"trait_ref":{"id":1,"generics":{"regions":[],"types":[{"Deduplicated":17}],"const_generics":[],"trait_refs":[]}},"item_name":"clone","reuses_default":true}},"is_global_initializer":null,"body":"Opaque"},null,{"def_id":585,"item_meta":{"name":[{"Ident":["alloc",0]},{"Ident":["alloc",0]},{"Impl":{"Trait":119}},{"Ident":["clone",0]}],"span":{"data":{"file_id":54,"beg":{"line":49,"col":15},"end":{"line":49,"col":20}},"generated_from_sp
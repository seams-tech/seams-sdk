t":{"id":{"Adt":72},"generics":{"regions":[{"Var":{"Free":0}}],"types":[{"Deduplicated":2215}],"const_generics":[],"trait_refs":[]}}}]}},"src":"TopLevel","is_global_initializer":null,"body":"Opaque"},{"def_id":487,"item_meta":{"name":[{"Ident":["alloc",0]},{"Ident":["vec",0]},{"Impl":{"Trait":142}},{"Ident":["deref_mut",0]}],"span":{"data":{"file_id":53,"beg":{"line":3671,"col":4},"end":{"line":3671,"col":39}},"generated_from_span":null},"source_text":null,"attr_info":{"attributes":[],"inline":"Hint","rename":null,"public":true},"is_local":false,"opacity":"Foreign","lang_item":null},"generics":{"regions":[{"index":0,"name":null,"mutability":"Unknown"}],"types":[{"index":0,"name":"T"},{"index":1,"name":"A"}],"const_generics":[],"trait_clauses":[null],"regions_outlive":[],"types_outlive":[],"trait_type_constraints":[]},"signature":{"is_unsafe":false,"inputs":[{"HashConsedValue":[2400,{"Ref":[{"Var":{"Free":0}},{"Deduplicated":2257},"Mut"]}]}],"output":{"Deduplicated":2288}},"src":{"TraitImpl":{"impl_ref":{"id":142,"generics":{"regions":[],"types":[{"Deduplicated":2215},{"Deduplicated":2216}],"const_generics":[],"trait_refs":[null]}},"trait_ref":{"id":64,"generics":{"regions":[],"types":[{"Deduplicated":2257},{"Deduplicated":2249}],"const_generics":[],"trait_refs":[]}},"item_name":"deref_mut","reuses_default":true}},"is_global_initializer":null,"body":"Opaque"},{"def_id":488,"item_meta":{"name":[{"Ident":["core",0]},{"Ident":["slice",0]},{"Impl":{"Ty":{"params":{"regions":[],"types":[{"index":0,"name":"T"}],"const_generics":[],"trait_clauses":[],"regions_outlive":[],"types_outlive":[],"trait_type_constraints":[]},"skip_binder":{"Deduplicated":61},"kind":"InherentImplBlock"}}},{"Ident":["sort_unstable",0]}],"span":{"data":{"file_id":35,"beg":{"line":3133,"col":4},"end":{"line":3135,"col":15}},"generated_from_span":null},"source_text":null,"attr_info":{"attributes":[{"DocComment":" Sorts the slice in ascending order **without** preserving the initial order of equal elements."},{"DocComment":""},{"DocComment":" This sort is unstable (i.e., may reorder equal elements), in-place (i.e., does not"},{"DocComment":" allocate), and *O*(*n* \\* log(*n*)) worst-case."},{"DocComment":""},{"DocComment":" If the implementation of [`Ord`] for `T` does not implement a [total order], the function"},{"DocComment":" may panic; even if the function exits normally, the resulting order of elements in the slice"},{"DocComment":" is unspecified. See also the note on panicking below."},{"DocComment":""},{"DocComment":" For example `|a, b| (a - b).cmp(a)` is a comparison function that is neither transitive nor"},{"DocComment":" reflexive nor total, `a < b < c < a` with `a = 1, b = 2, c = 3`. For more information and"},{"DocComment":" examples see the [`Ord`] documentation."},{"DocComment":""},{"DocComment":""},{"DocComment":" All original elements will remain in the slice and any possible modifications via interior"},{"DocComment":" mutability are observed in the input. Same is true if the implementation of [`Ord`] for `T` panics."},{"DocComment":""},{"DocComment":" Sorting types that only implement [`PartialOrd`] such as [`f32`] and [`f64`] require"},{"DocComment":" additional precautions. For example, `f32::NAN != f32::NAN`, which doesn't fulfill the"},{"DocComment":" reflexivity requirement of [`Ord`]. By using an alternative comparison function with"},{"DocComment":" `slice::sort_unstable_by` such as [`f32::total_cmp`] or [`f64::total_cmp`] that defines a"},{"DocComment":" [total order] users can sort slices containing floating-point values. Alternatively, if all"},{"DocComment":" values in the slice are guaranteed to be in a subset for which [`PartialOrd::partial_cmp`]"},{"DocComment":" forms a [total order], it's possible to sort the slice with `sort_unstable_by(|a, b|"},{"DocComment":" a.partial_cmp(b).unwrap())`."},{"DocComment":""},{"DocComment":" # Current implementation"},{"DocComment":""},{"DocComment":" The current implementation is based on [ipnsort] by Lukas Bergdoll and Orson Peters, which"},{"DocComment":" combines the fast average case of quicksort with the fast worst case of heapsort, achieving"},{"DocComment":" linear time on fully sorted and reversed inputs. On inputs with k distinct elements, the"},{"DocComment":" expected time to sort the data is *O*(*n* \\* log(*k*))."},{"DocComment":""},{"DocComment":" It is typically faster than stable sorting, except in a few special cases, e.g., when the"},{"DocComment":" slice is partially sorted."},{"DocComment":""},{"DocComment":" # Panics"},{"DocComment":""},{"DocComment":" May panic if the implementation of [`Ord`] for `T` does not implement a [total order], or if"},{"DocComment":" the [`Ord`] implementation panics."},{"DocComment":""},{"DocComment":" # Examples"},{"DocComment":""},{"DocComment":" ```"},{"DocComment":" let mut v = [4, -5, 1, -3, 2];"},{"DocComment":""},{"DocComment":" v.sort_unstable();"},{"DocComment":" assert_eq!(v, [-5, -3, 1, 2, 4]);"},{"DocComment":" ```"},{"DocComment":""},{"DocComment":" [ipnsort]: https://github.com/Voultapher/sort-research-rs/tree/main/ipnsort"},{"DocComment":" [total order]: https://en.wikipedia.org/wiki/Total_order"}],"inline":"Hint","rename":null,"public":true},"is_local":false,"opacity":"Foreign","lang_item":null},"generics":{"regions":[{"index":0,"name":null,"mutability":"Unknown"}],"types":[{"index":0,"name":"T"}],"const_generics":[],"trait_clauses":[{"clause_id":0,"span":{"data":{"file_id":35,"beg":{"line":3135,"col":11},"end":{"line":3135,"col":14}},"generated_from_span":null},"origin":"WhereClauseOnFn","trait_":{"regions":[],"skip_binder":{"id":42,"generics":{"regions":[],"types":[{"Deduplicated":2215}],"const_generics":[],"trait_refs":[]}}}}],"regions_outlive":[],"types_outlive":[],"trait_type_constraints":[]},"signature":{"is_unsafe":false,"inputs":[{"Deduplicated":2288}],"output":{"Deduplicated":0}},"src":"TopLevel","is_global_initializer":null,"body":"Opaque"},{"def_id":489,"item_meta":{"name":[{"Ident":["alloc",0]},{"Ident":["vec",0]},{"Impl":{"Ty":{"params":{"regions":[],"types":[{"index":0,"name":"T"},{"index":1,"name":"A"}],"const_generics":[],"trait_clauses":[{"clause_id":0,"span":{"data":{"file_id":53,"beg":{"line":3555,"col":8},"end":{"line":3555,"col":17}},"generated_from_span":null},"origin":"WhereClauseOnImpl","trait_":{"regions":[],"skip_binder":{"id":4,"generics":{"regions":[],"types":[{"Deduplicated":8},{"Deduplicated":8}],"const_generics":[],"trait_refs":[]}}}},null],"regions_outlive":[],"types_outlive":[],"trait_type_constraints":[]},"skip_binder":{"Deduplicated":1767},"kind":"InherentImplBlock"}}},{"Ident":["dedup",0]}],"span":{"data":{"file_id":53,"beg":{"line":3572,"col":4},"end":{"line":3572,"col":27}},"generated_from_span":null},"source_text":null,"attr_info":{"attributes":[{"DocComment":" Removes consecutive repeated elements in the vector according to the"},{"DocComment":" [`PartialEq`] trait implementation."},{"DocComment":""},{"DocComment":" If the vector is sorted, this removes all duplicates."},{"DocComment":""},{"DocComment":" # Examples"},{"DocComment":""},{"DocComment":" ```"},{"DocComment":" let mut vec = vec![1, 2, 2, 3, 2];"},{"DocComment":""},{"DocComment":" vec.dedup();"},{"DocComment":""},{"DocComment":" assert_eq!(vec, [1, 2, 3, 2]);"},{"DocComment":" ```"}],"inline":"Hint","rename":null,"public":true},"is_local":false,"opacity":"Foreign","lang_item":null},"generics":{"regions":[{"index":0,"name":null,"mutability":"Unknown"}],"types":[{"index":0,"name":"T"},{"index":1,"name":"A"}],"const_generics":[],"trait_clauses":[{"clause_id":0,"span":{"data":{"file_id":53,"beg":{"line":3555,"col":8},"end":{"line":3555,"col":17}},"generated_from_span":null},"origin":"WhereClauseOnImpl","trait_":{"regions":[],"skip_binder":{"id":4,"generics":{"regions":[],"types":[{"Deduplicated":2215},{"Deduplicated":2215}],"const_generics":[],"trait_refs":[]}}}},null],"regions_outlive":[],"types_outlive":[],"trait_type_constraints":[]},"signature":{"
omment":""},{"DocComment":" [`std::time::SystemTime`]: ../../std/time/struct.SystemTime.html"},{"DocComment":""},{"DocComment":" # Examples"},{"DocComment":""},{"DocComment":" ## `Sub`tractable points"},{"DocComment":""},{"DocComment":" ```"},{"DocComment":" use std::ops::Sub;"},{"DocComment":""},{"DocComment":" #[derive(Debug, Copy, Clone, PartialEq)]"},{"DocComment":" struct Point {"},{"DocComment":"     x: i32,"},{"DocComment":"     y: i32,"},{"DocComment":" }"},{"DocComment":""},{"DocComment":" impl Sub for Point {"},{"DocComment":"     type Output = Self;"},{"DocComment":""},{"DocComment":"     fn sub(self, other: Self) -> Self::Output {"},{"DocComment":"         Self {"},{"DocComment":"             x: self.x - other.x,"},{"DocComment":"             y: self.y - other.y,"},{"DocComment":"         }"},{"DocComment":"     }"},{"DocComment":" }"},{"DocComment":""},{"DocComment":" assert_eq!(Point { x: 3, y: 3 } - Point { x: 2, y: 3 },"},{"DocComment":"            Point { x: 1, y: 0 });"},{"DocComment":" ```"},{"DocComment":""},{"DocComment":" ## Implementing `Sub` with generics"},{"DocComment":""},{"DocComment":" Here is an example of the same `Point` struct implementing the `Sub` trait"},{"DocComment":" using generics."},{"DocComment":""},{"DocComment":" ```"},{"DocComment":" use std::ops::Sub;"},{"DocComment":""},{"DocComment":" #[derive(Debug, PartialEq)]"},{"DocComment":" struct Point<T> {"},{"DocComment":"     x: T,"},{"DocComment":"     y: T,"},{"DocComment":" }"},{"DocComment":""},{"DocComment":" // Notice that the implementation uses the associated type `Output`."},{"DocComment":" impl<T: Sub<Output = T>> Sub for Point<T> {"},{"DocComment":"     type Output = Self;"},{"DocComment":""},{"DocComment":"     fn sub(self, other: Self) -> Self::Output {"},{"DocComment":"         Point {"},{"DocComment":"             x: self.x - other.x,"},{"DocComment":"             y: self.y - other.y,"},{"DocComment":"         }"},{"DocComment":"     }"},{"DocComment":" }"},{"D
{
  "name": "@seams/voice-id",
  "private": true,
  "type": "module",
  "scripts": {
    "type-check": "tsc --noEmit",
    "test": "tsx --test \"tests/**/*.test.ts\"",
    "dev": "vite demo --host 127.0.0.1 --port 5050",
    "dev:all": "node scripts/devAll.mjs",
    "dev:all:verifier": "node scripts/devAllWithVerifier.mjs",
    "dev:server": "tsx server/src/devServer.ts",
    "dev:verifier": "PYTHONPATH=verifier python3 verifier/voiceid_verifier/app.py serve_http",
    "bundle:guard": "node scripts/assertClientBundleBoundary.mjs",
    "worker:guard": "node scripts/assertWorkerBoundary.mjs",
    "server-integration:guard": "node scripts/assertServerIntegrationBoundary.mjs",
    "container:guard": "node scripts/assertContainerPackaging.mjs",
    "aws:guard": "node scripts/assertAwsDeploymentPackaging.mjs",
    "nitro:guard": "node scripts/assertNitroBridgePackaging.mjs",
    "robot:guard": "node scripts/assertRobotSidecarPackaging.mjs",
    "signing-architecture:guard": "node scripts/assertSigningArchitecture.mjs",
    "container:build:cloudflare": "docker build -f deploy/cloudflare/verifier-container/Dockerfile -t voiceid-verifier:local .",
    "smoke:python-http": "node scripts/smokePythonHttpApi.mjs",
    "fixtures:validate": "python3 verifier-spike/compare_models.py --manifest fixtures/voiceid-fixture-manifest.json",
    "fixtures:validate:media": "python3 verifier-spike/compare_models.py --manifest fixtures/voiceid-fixture-manifest.json --check-media",
    "fixtures:validate:json": "python3 verifier-spike/compare_models.py --manifest fixtures/voiceid-fixture-manifest.json --json",
    "fixtures:report": "python3 verifier-spike/compare_models.py --manifest fixtures/voiceid-fixture-manifest.json --report-template",
    "fixtures:evaluate:spectral": "python3 verifier-spike/evaluate_spectral_baseline.py --manifest fixtures/voiceid-fixture-manifest.json --check-media",
    "fixtures:evaluate:ecapa": "python3 verifier-spike/evaluate_speechbrain_ecapa.py --manifest fixtures/voiceid-fixture-manifest.json --check-media",
    "benchmark:run": "python3 verifier-spike/benchmark.py --manifest fixtures/voiceid-benchmark-manifest.json --json-out verifier-spike/reports/benchmark-inventory.json --report-out verifier-spike/reports/benchmark-inventory.md",
    "benchmark:test": "python3 verifier-spike/test_benchmark.py",
    "pad:evaluate": "python3 verifier-spike/evaluate_pad.py --manifest fixtures/voiceid-pad-evaluation.json",
    "pad:test": "python3 verifier-spike/test_evaluate_pad.py",
    "verifier:test": "python3 -m unittest discover verifier -p \"*test*.py\""
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "tsx": "^4.20.5",
    "typescript": "^5.8.3",
    "vite": "^8.0.0"
  }
}

{
  "name": "seams-site",
  "type": "module",
  "private": true,
  "scripts": {
    "vite": "vite --host localhost --port 3600",
    "caddy": "bash run_caddy.sh",
    "dev": "concurrently --kill-others --names site,caddy \"pnpm run vite\" \"pnpm run caddy\"",
    "build": "pnpm -C ../.. build:sdk-full && vite build",
    "typecheck": "pnpm -C ../../packages/sdk-web exec tsc -p tsconfig.client-types.json && tsc --noEmit",
    "preview": "vite preview --host localhost --port 3600"
  },
  "dependencies": {
    "@fontsource/hanken-grotesk": "^5.2.8",
    "@hot-labs/near-connect": "0.11.4",
    "@radix-ui/react-select": "^2.0.0",
    "@seams-internal/console-shared": "workspace:*",
    "@seams-internal/shared-ts": "workspace:*",
    "@seams/sdk": "workspace:*",
    "@tanstack/react-query": "^5.76.1",
    "borsh": "^2.0.0",
    "bs58": "^6.0.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.542.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "sonner": "^1.5.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.1.2",
    "typescript": "~5.8.3",
    "vite": "^8.0.0"
  }
}

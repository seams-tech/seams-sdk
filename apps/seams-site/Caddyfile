{
	auto_https disable_redirects
	log {
		level ERROR
	}
}

# App (Vite dev server)
localhost {
	tls internal
	encode gzip
	@app_wallet_assets {
		path /sdk/* /wallet-service /wallet-service/* /export-viewer /export-viewer/*
	}
	handle @app_wallet_assets {
		respond 404
	}
	handle {
		reverse_proxy localhost:3600
	}
}

# Docs host (VitePress dev server)
docs.localhost {
	tls internal
	encode gzip
	reverse_proxy localhost:5222
}

# Wallet host (static SDK wallet asset tree)
localhost:8443 {
	tls internal
	encode gzip
	root * {$SEAMS_WALLET_PUBLIC_ROOT}

	@wallet_documents {
		path /wallet-service /wallet-service/ /export-viewer /export-viewer/
	}
	header @wallet_documents Cache-Control "no-store, max-age=0"
	header @wallet_documents Content-Security-Policy "frame-ancestors 'self' http://localhost:* https://localhost:*"

	@sdk_assets path /sdk/*
	header @sdk_assets Cache-Control "no-store, max-age=0"
	header @sdk_assets Access-Control-Allow-Origin "*"
	header @sdk_assets Access-Control-Allow-Methods "GET,OPTIONS"
	header @sdk_assets Access-Control-Allow-Headers "Content-Type,Range"
	header @sdk_assets -Content-Security-Policy
	header @sdk_assets -Cross-Origin-Embedder-Policy
	header @sdk_assets -Cross-Origin-Opener-Policy
	header @sdk_assets -Cross-Origin-Resource-Policy
	header @sdk_assets -Permissions-Policy
	@sdk_preflight {
		method OPTIONS
		path /sdk/*
	}
	respond @sdk_preflight 204

	handle /wallet-service {
		rewrite * /wallet-service/index.html
		file_server
	}
	handle /wallet-service/ {
		rewrite * /wallet-service/index.html
		file_server
	}
	handle /export-viewer {
		rewrite * /export-viewer/index.html
		file_server
	}
	handle /export-viewer/ {
		rewrite * /export-viewer/index.html
		file_server
	}
	handle /sdk/* {
		file_server
	}
	handle /wallet-assets.manifest.json {
		file_server
	}
	handle /headers.manifest.json {
		file_server
	}
	handle {
		respond "Seams wallet asset origin" 200
	}
}

# Router server on separate origin
localhost:9444 {
	tls internal
	encode gzip
	@router_allowed_origin header_regexp router_origin Origin ^https://localhost(:8443)?$
	@router_preflight {
		method OPTIONS
		header_regexp Origin ^https://localhost(:8443)?$
	}
	header @router_allowed_origin Access-Control-Allow-Origin {http.request.header.Origin}
	header @router_allowed_origin Access-Control-Allow-Credentials true
	header @router_allowed_origin Access-Control-Allow-Methods "GET,POST,PUT,PATCH,DELETE,OPTIONS"
	header @router_allowed_origin Access-Control-Allow-Headers "Content-Type,Authorization,X-Seams-Environment-Id,X-Environment-Id,X-Console-Org-Id,X-Console-User-Id,X-Console-Roles,X-Console-Project-Id,X-Console-Environment-Id,X-Console-Stripe-Webhook-Secret"
	header @router_allowed_origin Vary Origin
	respond @router_preflight 204
	reverse_proxy 127.0.0.1:9090 {
		header_down -Access-Control-Allow-Origin
		header_down -Access-Control-Allow-Credentials
		header_down -Access-Control-Allow-Methods
		header_down -Access-Control-Allow-Headers
		header_down -Vary
	}
	handle_errors {
		@router_optional_probe path /session/state /auth/google/options /.well-known/webauthn /.well-known/webauthn/
		@router_session_state path /session/state
		@router_google_options path /auth/google/options
		@router_well_known_webauthn path /.well-known/webauthn /.well-known/webauthn/
		header @router_optional_probe Content-Type "application/json; charset=utf-8"
		header @router_optional_probe Cache-Control "no-store"
		respond @router_session_state `{"authenticated":false,"routerAvailable":false}` 200
		respond @router_google_options `{"ok":true,"configured":false,"routerAvailable":false,"message":"Router API server is unavailable"}` 200
		respond @router_well_known_webauthn `{"origins":[],"capabilities":{"signingSessionSeal":{"mode":"none"}},"routerAvailable":false}` 200
	}
}


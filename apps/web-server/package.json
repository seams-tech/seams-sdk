{
  "name": "relay-server",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc -w --preserveWatchOutput",
    "start": "node dist/index.js",
    "dev": "node ./scripts/dev.mjs",
    "dev:threshold:3relays": "node ./scripts/dev-threshold-3relays.mjs",
    "signing-session-seal:keygen": "node ./scripts/generate-signing-session-seal-keys.mjs",
    "postgres:up": "node ./scripts/postgres-up.mjs",
    "postgres:down": "node ./scripts/postgres-down.mjs",
    "postgres:bootstrap:split": "node ./scripts/postgres-bootstrap-split-domains.mjs",
    "postgres:migrate:signer": "node ./scripts/postgres-migrate-signer.mjs",
    "postgres:migrate:console": "node ./scripts/postgres-migrate-console.mjs",
    "postgres:migrate:split-from-monolith": "node ./scripts/postgres-migrate-monolith-to-split.mjs",
    "postgres:verify:split": "node ./scripts/postgres-verify-split-domains.mjs",
    "postgres:migrate:all": "pnpm run postgres:migrate:signer && pnpm run postgres:migrate:console",
    "postgres:setup:split": "pnpm run postgres:up && pnpm run postgres:bootstrap:split && pnpm run postgres:migrate:all && pnpm run postgres:verify:split"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@seams/sdk": "workspace:*",
    "@seams/sdk-server": "workspace:*",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.23",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.7.4",
    "typescript": "^5.6.2"
  }
}

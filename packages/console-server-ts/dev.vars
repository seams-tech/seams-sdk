# Local Router API secrets template.
#
# Rename or copy this file to either:
#
#   packages/sdk-server-ts/.dev.vars
#   packages/console-server-ts/.dev.vars
#
# Then fill in the real values. Do not commit .dev.vars. The local D1
# launcher loads the sdk-server-ts file first, then the console-server-ts file.

# Required for the local "Fund account" test button for implicit NEAR accounts.
RELAYER_ACCOUNT_ID=w3a-relayer.testnet
RELAYER_PRIVATE_KEY=ed25519:<fill-local-testnet-relayer-private-key>

# Local testnet funding settings.
NEAR_RPC_URL=https://test.rpc.fastnear.com
ACCOUNT_INITIAL_BALANCE=30000000000000000000000
ENABLE_IMPLICIT_NEAR_ACCOUNT_TEST_FUNDING=true

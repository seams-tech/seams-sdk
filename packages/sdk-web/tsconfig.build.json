{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist/types",
    "emitDeclarationOnly": true,
    "noEmit": false,
    "strict": true,
    "rootDir": ".."
  },
  "include": [
    "src/**/*",
    "../sdk-server-ts/src/**/*",
    "../shared-ts/src/**/*",
    "build-paths.ts"
  ],
  "exclude": [
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "../sdk-server-ts/src/**/*.test.ts",
    "../sdk-server-ts/src/**/*.test.tsx",
    "../../examples/",
    "../../apps/",
    "../../docs/",
    "../../tests/"
  ]
}

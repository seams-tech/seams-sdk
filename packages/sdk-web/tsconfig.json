{
  "compilerOptions": {
    "target": "es2022",
    "lib": ["es2022", "dom", "dom.iterable"],
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "allowImportingTsExtensions": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": ".",
    "types": ["@playwright/test", "node", "react", "react-dom", "qrcode", "pg"],
    "typeRoots": [
      "./node_modules/@types",
      "../node_modules/@types",
      "../../node_modules/@types",
      "./node_modules",
      "../node_modules",
      "../../node_modules"
    ],
    "useDefineForClassFields": false,
    "paths": {
      "@/core/runtime": ["../sdk-runtime-ts/src/runtime/index.ts"],
      "@/core/runtime/*": ["../sdk-runtime-ts/src/runtime/*"],
      "@seams-internal/runtime": ["../sdk-runtime-ts/src/index.ts"],
      "@seams-internal/runtime/*": ["../sdk-runtime-ts/src/*"],
      "@/*": ["src/*"],
      "@shared/*": ["../shared-ts/src/*"],
      "@server": ["../sdk-server-ts/src/index.ts"],
      "@server/*": ["../sdk-server-ts/src/*"],
      "@seams/sdk/advanced": ["src/advanced.ts"],
      "@seams/sdk/server": ["../sdk-server-ts/src/index.ts"],
      "@seams/sdk/server/router/cloudflare": ["../sdk-server-ts/src/router/cloudflare-adaptor.ts"],
      "@seams/sdk/server/router/express": ["../sdk-server-ts/src/router/express-adaptor.ts"],
      "@seams/sdk/server/router/ror": ["../sdk-server-ts/src/router/ror-adaptor.ts"],
      "@seams/sdk/server/wasm/signer": ["../sdk-server-ts/src/wasm/signer.ts"],
      "@build-paths": ["./build-paths.ts"],
      "react": ["./node_modules/@types/react/index.d.ts"],
      "react/jsx-runtime": ["./node_modules/@types/react/jsx-runtime.d.ts"],
      "react-dom": ["./node_modules/@types/react-dom/index.d.ts"],
      "react-dom/client": ["./node_modules/@types/react-dom/client.d.ts"],
      "react-dom/server": ["./node_modules/@types/react-dom/server.d.ts"],
      "qrcode": ["./node_modules/@types/qrcode/index.d.ts"],
      "pg": ["./node_modules/@types/pg/index.d.ts"],
      "*": ["./node_modules/*", "../node_modules/*", "../../node_modules/*"]
    }
  },
  "include": [
    "src/**/*",
    "../sdk-runtime-ts/src/**/*",
    "../sdk-server-ts/src/**/*",
    "../shared-ts/src/**/*",
    "../../tests/**/*"
  ],
  "exclude": ["node_modules", "dist", "../dist", "../../tests/scripts/**/*"]
}

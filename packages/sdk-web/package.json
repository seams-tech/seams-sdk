{
  "name": "@seams/sdk",
  "version": "0.46.0",
  "type": "module",
  "description": "Seams web and runtime TypeScript SDK for NEAR and EVM-family wallets",
  "main": "./dist/esm/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/sdk-web/src/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "import": "./dist/esm/index.js",
      "default": "./dist/esm/index.js",
      "types": "./dist/types/sdk-web/src/index.d.ts"
    },
    "./advanced": {
      "import": "./dist/esm/advanced.js",
      "default": "./dist/esm/advanced.js",
      "types": "./dist/types/sdk-web/src/advanced.d.ts"
    },
    "./threshold": {
      "import": "./dist/esm/threshold.js",
      "default": "./dist/esm/threshold.js",
      "types": "./dist/types/sdk-web/src/threshold.d.ts"
    },
    "./runtime": {
      "import": "./dist/esm/runtime.js",
      "default": "./dist/esm/runtime.js",
      "types": "./dist/types/sdk-web/src/runtime.d.ts"
    },
    "./react": {
      "import": "./dist/esm/react/index.js",
      "default": "./dist/esm/react/index.js",
      "types": "./dist/types/sdk-web/src/react/index.d.ts"
    },
    "./react/profile": {
      "import": "./dist/esm/react/components/AccountMenuButton/index.js",
      "default": "./dist/esm/react/components/AccountMenuButton/index.js",
      "types": "./dist/types/sdk-web/src/react/components/AccountMenuButton/index.d.ts"
    },
    "./react/seams-auth-menu": {
      "import": "./dist/esm/react/components/SeamsAuthMenu/public.js",
      "default": "./dist/esm/react/components/SeamsAuthMenu/public.js",
      "types": "./dist/types/sdk-web/src/react/components/SeamsAuthMenu/public.d.ts"
    },
    "./react/seams-auth-menu/client": {
      "import": "./dist/esm/react/components/SeamsAuthMenu/client.js",
      "default": "./dist/esm/react/components/SeamsAuthMenu/client.js",
      "types": "./dist/types/sdk-web/src/react/components/SeamsAuthMenu/client.d.ts"
    },
    "./react/seams-auth-menu/skeleton": {
      "import": "./dist/esm/react/components/SeamsAuthMenu/skeleton.js",
      "default": "./dist/esm/react/components/SeamsAuthMenu/skeleton.js",
      "types": "./dist/types/sdk-web/src/react/components/SeamsAuthMenu/skeleton.d.ts"
    },
    "./react/seams-auth-menu/preload": {
      "import": "./dist/esm/react/components/SeamsAuthMenu/preload.js",
      "default": "./dist/esm/react/components/SeamsAuthMenu/preload.js",
      "types": "./dist/types/sdk-web/src/react/components/SeamsAuthMenu/preload.d.ts"
    },
    "./react/provider": {
      "import": "./dist/esm/react/context/SeamsWebProvider.js",
      "default": "./dist/esm/react/context/SeamsWebProvider.js",
      "types": "./dist/types/sdk-web/src/react/context/SeamsWebProvider.d.ts"
    },
    "./react/styles": "./dist/esm/react/styles/styles.css",
    "./web/wallet-iframe-client-html": {
      "import": "./dist/esm/SeamsWeb/walletIframe/client/html.js",
      "default": "./dist/esm/SeamsWeb/walletIframe/client/html.js",
      "types": "./dist/types/sdk-web/src/SeamsWeb/walletIframe/client/html.d.ts"
    }
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "typesVersions": {
    "*": {
      "threshold": [
        "dist/types/sdk-web/src/threshold.d.ts"
      ],
      "advanced": [
        "dist/types/sdk-web/src/advanced.d.ts"
      ],
      "runtime": [
        "dist/types/sdk-web/src/runtime.d.ts"
      ],
      "react": [
        "dist/types/sdk-web/src/react/index.d.ts"
      ],
      "react/*": [
        "dist/types/sdk-web/src/react/*"
      ]
    }
  },
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "build:sdk": "./scripts/build/build-sdk.sh",
    "build:wasm": "./scripts/build/build-wasm.sh",
    "build:sdk-full": "./scripts/build/build-full.sh",
    "build:prod": "./scripts/build/build-prod.sh",
    "build:static-wallet-assets": "node ./scripts/build/emit-static-wallet-assets.mjs",
    "build:rolldown": "rolldown -c rolldown.config.ts",
    "dev": "rolldown -c rolldown.config.ts -w",
    "test": "pnpm -C ../../tests test",
    "test:lite": "pnpm -C ../../tests test:lite",
    "test:inline": "pnpm -C ../../tests test:inline",
    "test:e2e": "pnpm -C ../../tests test:e2e",
    "test:unit": "pnpm -C ../../tests test:unit",
    "test:source-guards": "pnpm -C ../../tests test:source-guards",
    "test:integration:signing": "pnpm -C ../../tests test:integration:signing",
    "test:threshold-core": "pnpm -C ../../tests test:threshold-core",
    "smoke:evm-crypto:node-runtime": "node ./scripts/smoke/smoke-evm-crypto-node-runtime.mjs",
    "smoke:evm-crypto:workers-runtime": "node ./scripts/smoke/smoke-evm-crypto-workers-runtime.mjs",
    "smoke:evm-crypto:runtimes": "pnpm smoke:evm-crypto:node-runtime && pnpm smoke:evm-crypto:workers-runtime",
    "test:wallet-iframe": "pnpm -C ../../tests test:wallet-iframe",
    "test:lit-components": "pnpm -C ../../tests test:lit-components",
    "test:relayer": "pnpm -C ../../tests test:relayer",
    "build:check:fresh": "./scripts/build/check-build-freshness.sh",
    "check:bundle-size": "node ./scripts/checks/report-wallet-iframe-bundle-size.mjs",
    "check:runtime-entry-bundles": "node ./scripts/checks/assert-runtime-entry-bundles.mjs",
    "check:static-wallet-assets": "node ./scripts/checks/assert-static-wallet-assets.mjs",
    "check:hosted-wallet-docs": "node ./scripts/checks/assert-hosted-wallet-docs.mjs",
    "smoke:static-wallet-origin": "node ./scripts/checks/smoke-static-wallet-origin.mjs",
    "check:wasm-exports": "node ./scripts/checks/report-wasm-export-surface.mjs",
    "size:lite": "node ./scripts/reports/report-lite-bundle-sizes.mjs",
    "size:lite:check": "node ./scripts/reports/report-lite-bundle-sizes.mjs --check",
    "evidence:yaos-ab:local-artifacts": "node ./scripts/reports/report-yaos-ab-local-artifacts.mjs ../../docs/evidence/yaos-ab-phase14b-local-artifacts-v1.json",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "seams",
    "wallet",
    "signing-runtime",
    "browser",
    "NEAR",
    "EVM",
    "blockchain",
    "passkey",
    "react",
    "typescript",
    "sdk"
  ],
  "author": "web3authn.org",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/web3-authn/sdk.git"
  },
  "bugs": {
    "url": "https://github.com/web3-authn/sdk/issues"
  },
  "homepage": "https://github.com/web3-authn",
  "peerDependencies": {
    "jsqr": ">=1.4.0",
    "qrcode": ">=1.3.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "qrcode": {
      "optional": true
    },
    "jsqr": {
      "optional": true
    }
  },
  "dependencies": {
    "@lit/react": "^1.0.8",
    "@noble/hashes": "^2.0.1",
    "bs58": "^6.0.0",
    "idb": "^8.0.3",
    "lit": "^3.3.1",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@simplewebauthn/server": "^13.2.2",
    "@near-js/types": "^2.4.0",
    "@types/express": "^4.17.21",
    "@types/node": "^20.19.9",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "borsh": "^2.0.0",
    "express": "^4.21.2",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "rolldown": "^1.0.0-beta.27",
    "rollup-plugin-css-only": "^4.5.2",
    "typescript": "^5.8.3"
  }
}

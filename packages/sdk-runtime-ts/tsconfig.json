{
  "extends": "../sdk-web/tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/core/runtime": ["src/runtime/index.ts"],
      "@/core/runtime/*": ["src/runtime/*"],
      "@/*": ["../sdk-web/src/*"],
      "@shared/*": ["../shared-ts/src/*"],
      "@server": ["../sdk-server-ts/src/index.ts"],
      "@server/*": ["../sdk-server-ts/src/*"],
      "@build-paths": ["../sdk-web/build-paths.ts"]
    }
  },
  "include": ["src/**/*", "../sdk-web/src/core/**/*", "../shared-ts/src/**/*"],
  "exclude": ["node_modules", "dist"]
}

  "evidence_limits": [
    "This review did not rerun deployed workerd/Miniflare concurrency, crash, cancellation, alarm, point-in-time restore, or the already recorded cross-account transport campaign.",
    "Cloudflare platform consistency and output-gate behavior are documented assumptions, not locally re-proven.",
    "The independent reviewer covered the ECDSA lifecycle and an earlier same-turn Yao snapshot; the final Yao delta was reconciled by the primary review."
  ],
  "findings": [
    {
      "id": "CF-LC-001",
      "severity": "high",
      "status": "open",
      "summary": "Committed SigningWorker material remains durably serialized until a later finish mutation; crash recovery has no production invocation path."
    },
    {
      "id": "CF-LC-002",
      "severity": "medium",
      "status": "open",
      "summary": "Post-reservation failure paths and expired or retired available records do not all persist terminal tombstones."
    },
    {
      "id": "CF-LC-003",
      "severity": "medium",
      "status": "open",
      "summary": "Backup and point-in-time restore can revive pre-tombstone material unless deployment advances an independently authoritative epoch."
    },
    {
      "id": "CF-LC-004",
      "severity": "high",
      "status": "open",
      "summary": "Yao sessions claim Running once in the current generation, but lack terminal failure/expiry states, crash recovery, bounded retention, and a rollback-generation floor."
    },
    {
      "id": "CF-LC-005",
      "severity": "medium",
      "status": "open",
      "summary": "SigningWorker prepare does not cap reservation expiry at the minimum of request expiry, material expiry, and 60 seconds."
    },
    {
      "id": "CF-LC-006",
      "severity": "medium",
      "status": "open",
      "summary": "SigningWorker Yao activation duplicates plaintext scalar material across orchestration and output Durable Objects and does not retire failed or superseded material."
    }
  ]

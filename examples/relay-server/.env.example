# -----------------------------------------------------------------------------
# Process and browser origins
# -----------------------------------------------------------------------------
# Local relay process port. Caddy or another proxy may expose a separate HTTPS port.
# PORT=8444

# Browser app and wallet iframe origins allowed by the relay.
EXPECTED_ORIGIN=https://localhost
EXPECTED_WALLET_ORIGIN=https://localhost:8443

# ROR config served by the relay at /.well-known/webauthn.
# Defaults to hostname(EXPECTED_WALLET_ORIGIN).
# ROR_RP_ID=localhost
# ROR_ALLOWED_ORIGINS=https://app1.example.com,https://app2.example.com


# -----------------------------------------------------------------------------
# NEAR relayer account
# -----------------------------------------------------------------------------
RELAYER_ACCOUNT_ID=your-relayer.testnet
RELAYER_PRIVATE_KEY=ed25519:replace-with-your-relayer-private-key

# Optional override. Defaults to https://test.rpc.fastnear.com in this example.
# NEAR_RPC_URL=https://rpc.testnet.near.org


# -----------------------------------------------------------------------------
# App session and Google SSO / OIDC
# -----------------------------------------------------------------------------
# Enables JWT plus HttpOnly cookie app sessions.
JWT_SECRET=dev-relay-jwt-secret-change-me
JWT_ISSUER=relay-server
JWT_AUDIENCE=tatchi-app
JWT_EXPIRES_SEC=86400
SESSION_COOKIE_NAME=w3a_session
SESSION_SAME_SITE=Lax

# Google OIDC for /session/exchange with exchange.type=oidc_jwt.
# Provide one or more client ids; relay validates token audience against this list.
# GOOGLE_OIDC_CLIENT_ID=
# GOOGLE_OIDC_CLIENT_IDS=
# GOOGLE_OIDC_HOSTED_DOMAINS=


# -----------------------------------------------------------------------------
# Relay API key auth and managed registration
# -----------------------------------------------------------------------------
# When enabled, POST /registration/bootstrap requires an active key with
# accounts.create scope.
RELAY_API_KEY_AUTH_ENABLED=1


# Local dev automatically wires fixture signing-root secret shares for
# localhost/.local origins unless NODE_ENV=production. The authenticated
# project/environment runtime scope supplies signingRootId per request, and the
# active environment metadata supplies signingRootVersion=default for the dev
# fixture. Do not configure a process-wide signing root on the relay. Set
# explicitly only when running a non-production local harness with non-local
# origins.
# THRESHOLD_SIGNING_ROOT_LOCAL_DEV_RESOLVER=1


# -----------------------------------------------------------------------------
# Threshold signing service
# -----------------------------------------------------------------------------
# Coordinator mode serves threshold signing routes. Cosigner mode is used only
# when running a multi-process relay fleet.
THRESHOLD_NODE_ROLE=coordinator

# Share mode for Ed25519 threshold signing.
THRESHOLD_ED25519_SHARE_MODE=derived

# Coordinator/cosigner shared secret for multi-process relayer cosigning.
# Required when THRESHOLD_NODE_ROLE=cosigner.
# THRESHOLD_COORDINATOR_SHARED_SECRET_B64U=


# -----------------------------------------------------------------------------
# Email OTP and signing-session Shamir3Pass seal
# -----------------------------------------------------------------------------
# Signing-session seal routes:
# - POST /threshold/signing-session-seal/apply-server-seal
# - POST /threshold/signing-session-seal/remove-server-seal
#
# Generate matching server/client values with: pnpm signing-session-seal:keygen
SIGNING_SESSION_SEAL_ENABLED=1
SIGNING_SESSION_SEAL_KEY_VERSION=kek-s-2026-02
SIGNING_SESSION_SHAMIR_P_B64U=
SIGNING_SESSION_SEAL_E_S_B64U=
SIGNING_SESSION_SEAL_D_S_B64U=

# Optional signing-session seal route rate limits.
# SIGNING_SESSION_SEAL_RATE_LIMIT_KIND=in-memory
# SIGNING_SESSION_SEAL_RATE_LIMIT=30
# SIGNING_SESSION_SEAL_RATE_LIMIT_WINDOW_MS=60000
# SIGNING_SESSION_SEAL_RATE_LIMIT_KEY_PREFIX=threshold:signing-session-seal:rate:

# Optional signing-session seal idempotency replay backend.
# Leave unset to disable persisted replay cache; single-flight still applies per process.
# Supported kinds: in-memory, upstash-redis-rest, redis-tcp, postgres.
# SIGNING_SESSION_SEAL_IDEMPOTENCY_KIND=in-memory
# SIGNING_SESSION_SEAL_IDEMPOTENCY_TTL_MS=90000
# SIGNING_SESSION_SEAL_IDEMPOTENCY_KEY_PREFIX=threshold:signing-session-seal:idempotency:
# SIGNING_SESSION_SEAL_IDEMPOTENCY_UPSTASH_URL=
# SIGNING_SESSION_SEAL_IDEMPOTENCY_UPSTASH_TOKEN=
# SIGNING_SESSION_SEAL_IDEMPOTENCY_REDIS_URL=
# SIGNING_SESSION_SEAL_IDEMPOTENCY_POSTGRES_URL=
# SIGNING_SESSION_SEAL_IDEMPOTENCY_POSTGRES_NAMESPACE=

# Email OTP defaults to development memory delivery locally. The relay prints
# [email-otp] development OTP code with devOtpCode in non-production memory or
# log delivery modes. Production rejects memory/log delivery modes.
# EMAIL_OTP_DELIVERY_MODE=memory
# EMAIL_OTP_DEV_OUTBOX_ENABLED=true
# EMAIL_OTP_MAX_ACTIVE_CHALLENGES_PER_CONTEXT=5

# Required for hosted Email OTP/OIDC account IDs. The relay uses this secret to
# derive deterministic privacy-preserving NEAR account slugs. Do not reuse JWT,
# signing-root, Email OTP seal, or database encryption secrets.
# ACCOUNT_ID_DERIVATION_SECRET=replace-with-a-long-random-account-id-secret

# Non-production defaults are local-friendly. Production deploys should set
# explicit limits and a real limiter backend.
# EMAIL_OTP_RATE_LIMITER_KIND=in-memory
# EMAIL_OTP_RATE_LIMIT_KEY_PREFIX=email-otp:v2:
# EMAIL_OTP_CHALLENGE_RATE_LIMIT_MAX=100
# EMAIL_OTP_CHALLENGE_RATE_LIMIT_WINDOW_MS=60000
# EMAIL_OTP_VERIFY_RATE_LIMIT_MAX=100
# EMAIL_OTP_VERIFY_RATE_LIMIT_WINDOW_MS=60000
# EMAIL_OTP_GRANT_RATE_LIMIT_MAX=100
# EMAIL_OTP_GRANT_RATE_LIMIT_WINDOW_MS=60000

# Optional Email OTP-specific backend overrides. Defaults fall back to shared
# UPSTASH_REDIS_REST_* or REDIS_URL when a matching limiter backend is selected.
# EMAIL_OTP_RATE_LIMIT_UPSTASH_URL=
# EMAIL_OTP_RATE_LIMIT_UPSTASH_TOKEN=
# EMAIL_OTP_RATE_LIMIT_REDIS_URL=


# -----------------------------------------------------------------------------
# Sponsored execution / Tempo demo
# -----------------------------------------------------------------------------
# Optional sponsored EVM route for the demo Drip Fee Tokens button. The relay
# executes a generic single-call sponsorship route, but the seeded local runtime
# policy only allows dripTo(address,address[]) on chain 42431.
# SPONSORED_EVM_EXECUTORS_JSON={"42431":{"rpcUrl":"https://rpc.moderato.tempo.xyz","sponsorPrivateKeyHex":"0x...","maxPriorityFeePerGasFloor":"2000000000","maxFeePerGasFloor":"40000000000"}}

# Optional static pricing adapter for capped sponsorship policies.
# SPONSORED_EXECUTION_STATIC_PRICING_JSON={"evm":{"42431":{"estimateFeePerGas":"22000000000","minorPerFeeUnitNumerator":"100","minorPerFeeUnitDenominator":"1000000000000000000","pricingVersion":"static-tempo-testnet-v1"}},"near":{"TESTNET":{"estimateFeeAmountYocto":"2000","minorPerFeeUnitNumerator":"1","minorPerFeeUnitDenominator":"1000","pricingVersion":"static-near-testnet-v1"}}}

# Optional real pricing adapter for capped sponsorship policies. Real pricing
# currently supports EVM native gas spend using live eth_gasPrice and CoinGecko.
# SPONSORED_EXECUTION_REAL_PRICING_JSON={"provider":"coingecko","cacheTtlMs":300000,"evm":{"42431":{"rpcUrl":"https://rpc.moderato.tempo.xyz","assetId":"near","nativeUnitDecimals":18,"pricingVersionPrefix":"coingecko-tempo-testnet"}},"near":{"TESTNET":{"assetId":"near","nativeUnitDecimals":24,"estimateFeeAmountYocto":"2000","pricingVersionPrefix":"coingecko-near-testnet"}}}

# Optional override for the seeded onboarding sponsorship contract target.
# TEMPO_ONBOARDING_FAUCET_CONTRACT=0xbb85080E6953f25197ec68798360667140EbAf4b


# -----------------------------------------------------------------------------
# Persistence
# -----------------------------------------------------------------------------
# Runtime/signer DB connection used at runtime. Use a signer-scoped DB user.
POSTGRES_URL=postgres://seams_signer:seams_signer@127.0.0.1:5432/seams_signer

# Optional signer migration-only connection.
# POSTGRES_MIGRATION_URL=postgres://seams_signer_migrator:seams_signer_migrator@127.0.0.1:5432/seams_signer

# Optional console DB runtime connection. Keep this separate from POSTGRES_URL.
# CONSOLE_POSTGRES_URL=postgres://seams_console:seams_console@127.0.0.1:5432/seams_console

# Optional console migration-only connection.
# CONSOLE_POSTGRES_MIGRATION_URL=postgres://seams_console_migrator:seams_console_migrator@127.0.0.1:5432/seams_console

# Upstash REST (Cloudflare-friendly).
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Redis TCP (Node-only).
# REDIS_URL=redis://127.0.0.1:6379


# -----------------------------------------------------------------------------
# Local Postgres bootstrap helpers
# -----------------------------------------------------------------------------
# Optional split-domain bootstrap/verify overrides used by:
# - pnpm run postgres:bootstrap:split
# - pnpm run postgres:verify:split
# - pnpm run postgres:setup:split
# POSTGRES_BOOTSTRAP_ADMIN_USER=tatchi
# POSTGRES_BOOTSTRAP_HOST=127.0.0.1
# POSTGRES_BOOTSTRAP_PORT=5432
# SIGNER_DB_NAME=seams_signer
# SIGNER_RUNTIME_USER=seams_signer
# SIGNER_RUNTIME_PASSWORD=seams_signer
# SIGNER_MIGRATOR_USER=seams_signer_migrator
# SIGNER_MIGRATOR_PASSWORD=seams_signer_migrator
# CONSOLE_DB_NAME=seams_console
# CONSOLE_RUNTIME_USER=seams_console
# CONSOLE_RUNTIME_PASSWORD=seams_console
# CONSOLE_MIGRATOR_USER=seams_console_migrator
# CONSOLE_MIGRATOR_PASSWORD=seams_console_migrator


# -----------------------------------------------------------------------------
# Console/admin demo
# -----------------------------------------------------------------------------
# Demo seed data for /console/org, /console/projects, /console/environments, and
# /console/members. Enabled by default to make dashboard live-testing easier.
CONSOLE_DEMO_SEED_ENABLED=1
CONSOLE_DEMO_ORG_ID=org-dev
CONSOLE_DEMO_PROJECT_ID=proj_console_core
CONSOLE_DEMO_ENVIRONMENT_ID=proj_console_core-prod

# Comma-separated additional roles used for first-login SSO role bootstrap.
# owner/admin are always included during bootstrap.
CONSOLE_DEMO_ROLES=admin
# CONSOLE_SSO_DEFAULT_ROLES=admin

# Console/admin owner allowlist.
# CONSOLE_PLATFORM_ADMIN_EMAILS=admin@example.com


# -----------------------------------------------------------------------------
# Console billing and Stripe
# -----------------------------------------------------------------------------
# Billing backend: postgres or memory. Defaults to postgres when
# CONSOLE_POSTGRES_URL is set, otherwise memory.
# CONSOLE_BILLING_BACKEND=postgres
# CONSOLE_BILLING_ENSURE_SCHEMA=1
# CONSOLE_BILLING_NAMESPACE=relay-console

# Billing Stripe webhook shared secret.
# CONSOLE_BILLING_STRIPE_WEBHOOK_SECRET=replace-with-strong-random-secret

# Optional live Stripe API credentials for billing provider routes. When unset,
# relay uses deterministic mock Stripe providers.
# STRIPE_API_SK=sk_test_...
# STRIPE_API_PK=pk_test_...
# STRIPE_CHECKOUT_PRICE_ID=price_...
# STRIPE_API_BASE_URL=https://api.stripe.com
# STRIPE_API_TIMEOUT_MS=15000


# -----------------------------------------------------------------------------
# Console webhooks
# -----------------------------------------------------------------------------
# Backend: postgres or memory. Defaults to postgres when CONSOLE_POSTGRES_URL is
# set, otherwise memory.
# CONSOLE_WEBHOOKS_BACKEND=postgres
# CONSOLE_WEBHOOKS_ENSURE_SCHEMA=1
# CONSOLE_WEBHOOKS_NAMESPACE=relay-console


# -----------------------------------------------------------------------------
# Console observability
# -----------------------------------------------------------------------------
# Backend: postgres or memory. Defaults to postgres when CONSOLE_POSTGRES_URL is
# set, otherwise memory.
# CONSOLE_OBSERVABILITY_BACKEND=postgres
# CONSOLE_OBSERVABILITY_ENSURE_SCHEMA=1
# CONSOLE_OBSERVABILITY_NAMESPACE=relay-console
# CONSOLE_OBSERVABILITY_QUERY_MAX_WINDOW_MS=604800000
# CONSOLE_OBSERVABILITY_INGEST_MAX_BATCH_SIZE=200
# CONSOLE_OBSERVABILITY_INGEST_MAX_EVENTS_PER_MINUTE=10000
# CONSOLE_OBSERVABILITY_RETENTION_TTL_MS=2592000000
# CONSOLE_OBSERVABILITY_RETENTION_PRUNE_INTERVAL_MS=300000
# CONSOLE_OBSERVABILITY_RETENTION_BATCH_SIZE=1000

# Runtime snapshots are versioned effective config, not error logs. The
# retention cleanup keeps the latest snapshot per org/project/environment.
# CONSOLE_RUNTIME_SNAPSHOT_RETENTION_TTL_MS=604800000
# CONSOLE_RUNTIME_SNAPSHOT_RETENTION_PRUNE_INTERVAL_MS=300000
# CONSOLE_RUNTIME_SNAPSHOT_RETENTION_BATCH_SIZE=1000

RELAYER_ACCOUNT_ID=your-relayer.testnet
RELAYER_PRIVATE_KEY=ed25519:replace-with-your-relayer-private-key

# ROR config served by the relay at `/.well-known/webauthn`
# Defaults to hostname(EXPECTED_WALLET_ORIGIN)
# ROR_RP_ID=localhost
# Comma-separated extra allowed origins (optional)
# ROR_ALLOWED_ORIGINS=https://app1.example.com,https://app2.example.com

# Optional override (defaults to https://test.rpc.fastnear.com in this example)
# NEAR_RPC_URL=https://rpc.testnet.near.org

# Local dev relay process port (Caddy can expose a separate public HTTPS port)
# PORT=8444

EXPECTED_ORIGIN=https://localhost
EXPECTED_WALLET_ORIGIN=https://localhost:8443

# Session (optional; enables JWT + HttpOnly cookie)
JWT_SECRET=dev-relay-jwt-secret-change-me
JWT_ISSUER=relay-server
JWT_AUDIENCE=tatchi-app
JWT_EXPIRES_SEC=86400
SESSION_COOKIE_NAME=w3a_session
SESSION_SAME_SITE=Lax
# Google OIDC for /session/exchange (exchange.type=oidc_jwt).
# Provide one or more client ids; relay validates audience against this list.
# GOOGLE_OIDC_CLIENT_ID=
# GOOGLE_OIDC_CLIENT_IDS=
# Optional hosted-domain allowlist used by /auth/google/verify.
# GOOGLE_OIDC_HOSTED_DOMAINS=

# Relay API key auth for gas-costing registration route.
# When enabled, POST /registration/bootstrap requires an active key with `accounts.create` scope.
RELAY_API_KEY_AUTH_ENABLED=1

# Threshold Ed25519 (2p FROST) signing.
THRESHOLD_ED25519_SHARE_MODE=derived
# 32-byte base64url local-dev sample secret. Replace for shared/non-dev deployments.
THRESHOLD_ED25519_MASTER_SECRET_B64U=
# Required for threshold ECDSA provisioning/signing.
THRESHOLD_SECP256K1_MASTER_SECRET_B64U=

# Coordinator/cosigner wiring (optional; used when running a multi-process relay fleet).
THRESHOLD_NODE_ROLE=coordinator
# 32-byte base64url local-dev sample secret.
THRESHOLD_COORDINATOR_SHARED_SECRET_B64U=

# PRF session seal routes (server-side 3-pass unlock module):
# - POST /threshold-ecdsa/prf-seal/apply-server-seal
# - POST /threshold-ecdsa/prf-seal/remove-server-seal
PRF_SESSION_SEAL_ENABLED=1
PRF_SESSION_SEAL_KEY_VERSION=kek-s-2026-02
# Generate with: pnpm prf-seal:keygen
SHAMIR_P_B64U=
SHAMIR_E_S_B64U=
SHAMIR_D_S_B64U=
# Optional route rate limit config:
PRF_SESSION_SEAL_RATE_LIMIT_KIND=in-memory
PRF_SESSION_SEAL_RATE_LIMIT=30
PRF_SESSION_SEAL_RATE_LIMIT_WINDOW_MS=60000
PRF_SESSION_SEAL_RATE_LIMIT_KEY_PREFIX=threshold:prf-seal:rate:
# Optional idempotency replay backend:
# - leave unset to disable persisted replay cache (single-flight still applies per process)
# - set kind to enable (`in-memory` | `upstash-redis-rest` | `redis-tcp`)
# PRF_SESSION_SEAL_IDEMPOTENCY_KIND=in-memory
# PRF_SESSION_SEAL_IDEMPOTENCY_TTL_MS=90000
# PRF_SESSION_SEAL_IDEMPOTENCY_KEY_PREFIX=threshold:prf-seal:idempotency:
# Optional backend-specific overrides (defaults to shared UPSTASH/REDIS settings)
# PRF_SESSION_SEAL_IDEMPOTENCY_UPSTASH_URL=
# PRF_SESSION_SEAL_IDEMPOTENCY_UPSTASH_TOKEN=
# PRF_SESSION_SEAL_IDEMPOTENCY_REDIS_URL=
# PRF_SESSION_SEAL_IDEMPOTENCY_POSTGRES_URL=
# PRF_SESSION_SEAL_IDEMPOTENCY_POSTGRES_NAMESPACE=

# Optional persistence for threshold sessions (recommended for local dev).
# Runtime/signer DB connection used at runtime.
# Use a signer-scoped DB user.
POSTGRES_URL=postgres://tatchi_signer:tatchi_signer@127.0.0.1:5432/tatchi_signer

# Optional signer migration-only connection (preferred for least-privilege runtime users).
# POSTGRES_MIGRATION_URL=postgres://tatchi_signer_migrator:tatchi_signer_migrator@127.0.0.1:5432/tatchi_signer

# Optional console DB runtime connection (billing/webhooks/observability/admin console).
# Keep this separate from POSTGRES_URL (signer state).
# CONSOLE_POSTGRES_URL=postgres://tatchi_console:tatchi_console@127.0.0.1:5432/tatchi_console

# Optional console migration-only connection.
# CONSOLE_POSTGRES_MIGRATION_URL=postgres://tatchi_console_migrator:tatchi_console_migrator@127.0.0.1:5432/tatchi_console

# Optional split-domain bootstrap/verify overrides used by:
# - pnpm run postgres:bootstrap:split
# - pnpm run postgres:verify:split
# - pnpm run postgres:setup:split
# POSTGRES_BOOTSTRAP_ADMIN_USER=tatchi
# POSTGRES_BOOTSTRAP_HOST=127.0.0.1
# POSTGRES_BOOTSTRAP_PORT=5432
# SIGNER_DB_NAME=tatchi_signer
# SIGNER_RUNTIME_USER=tatchi_signer
# SIGNER_RUNTIME_PASSWORD=tatchi_signer
# SIGNER_MIGRATOR_USER=tatchi_signer_migrator
# SIGNER_MIGRATOR_PASSWORD=tatchi_signer_migrator
# CONSOLE_DB_NAME=tatchi_console
# CONSOLE_RUNTIME_USER=tatchi_console
# CONSOLE_RUNTIME_PASSWORD=tatchi_console
# CONSOLE_MIGRATOR_USER=tatchi_console_migrator
# CONSOLE_MIGRATOR_PASSWORD=tatchi_console_migrator

# Billing Stripe webhook shared secret.
# CONSOLE_BILLING_STRIPE_WEBHOOK_SECRET=replace-with-strong-random-secret

# Upstash REST (Cloudflare-friendly)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Redis TCP (Node-only)
# REDIS_URL=redis://127.0.0.1:6379

# Console/admin routes (mounted at /console/* in this example server)
# Demo seed data for /console/org + /console/projects + /console/environments + /console/members.
# Enabled by default to make dashboard live-testing easier in local/dev.
CONSOLE_DEMO_SEED_ENABLED=1
CONSOLE_DEMO_ORG_ID=org-dev
CONSOLE_DEMO_PROJECT_ID=proj_console_core
CONSOLE_DEMO_ENVIRONMENT_ID=proj_console_core-prod
# Comma-separated additional roles used for first-login SSO role bootstrap.
# owner/admin are always included during bootstrap; this value appends extra org roles.
# Falls back to this value when CONSOLE_SSO_DEFAULT_ROLES is unset.
CONSOLE_DEMO_ROLES=admin
# Optional override for additional first-login SSO bootstrap roles.
# owner/admin remain enforced.
# CONSOLE_SSO_DEFAULT_ROLES=admin

# Console billing backend:
# - postgres: persists billing data to Postgres
# - memory: in-memory billing data (ephemeral dev only)
# Defaults to postgres when CONSOLE_POSTGRES_URL is set, otherwise memory.
# CONSOLE_BILLING_BACKEND=postgres
# Set to 0/false to require explicit pre-run migrations and skip startup schema creation.
# CONSOLE_BILLING_ENSURE_SCHEMA=1
# CONSOLE_BILLING_NAMESPACE=relay-console

# Console webhooks backend:
# - postgres: persists webhook endpoint/delivery data to Postgres
# - memory: in-memory webhook data (ephemeral dev only)
# Defaults to postgres when CONSOLE_POSTGRES_URL is set, otherwise memory.
# CONSOLE_WEBHOOKS_BACKEND=postgres
# Set to 0/false to require explicit pre-run migrations and skip startup schema creation.
# CONSOLE_WEBHOOKS_ENSURE_SCHEMA=1
# CONSOLE_WEBHOOKS_NAMESPACE=relay-console

# Console observability backend:
# - postgres: persists console observability events with partitioning/TTL/backpressure guardrails
# - memory: in-memory observability read status (ephemeral dev only)
# Defaults to postgres when CONSOLE_POSTGRES_URL is set, otherwise memory.
# CONSOLE_OBSERVABILITY_BACKEND=postgres
# Set to 0/false to require explicit pre-run migrations and skip startup schema creation.
# CONSOLE_OBSERVABILITY_ENSURE_SCHEMA=1
# CONSOLE_OBSERVABILITY_NAMESPACE=relay-console
# Strict read-query window bound (default: 7 days).
# CONSOLE_OBSERVABILITY_QUERY_MAX_WINDOW_MS=604800000
# Ingest backpressure guardrails.
# CONSOLE_OBSERVABILITY_INGEST_MAX_BATCH_SIZE=200
# CONSOLE_OBSERVABILITY_INGEST_MAX_EVENTS_PER_MINUTE=10000
# Retention TTL guardrails.
# CONSOLE_OBSERVABILITY_RETENTION_TTL_MS=2592000000
# CONSOLE_OBSERVABILITY_RETENTION_PRUNE_INTERVAL_MS=300000
# CONSOLE_OBSERVABILITY_RETENTION_BATCH_SIZE=1000
# Optional live Stripe API credentials for billing provider routes.
# When STRIPE_API_SK is set, /console/billing/stripe/* endpoints use live Stripe API calls.
# When unset, relay uses deterministic mock Stripe providers.
# STRIPE_API_SK=sk_test_...
# Optional publishable key for frontend usage (relay logs presence but does not require it).
# STRIPE_API_PK=pk_test_...
# Optional default Stripe Price ID for checkout sessions.
# If unset, checkout uses dynamic inline price_data for local/demo use.
# STRIPE_CHECKOUT_PRICE_ID=price_...
# Optional Stripe API base URL override (default: https://api.stripe.com)
# STRIPE_API_BASE_URL=https://api.stripe.com
# Optional Stripe API request timeout in ms (default: 15000)
# STRIPE_API_TIMEOUT_MS=15000

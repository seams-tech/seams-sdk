RELAYER_ACCOUNT_ID=w3a-relayer.testnet
RELAYER_PRIVATE_KEY=ed25519:

# ROR config served by the relay at `/.well-known/webauthn`
# Defaults to hostname(EXPECTED_WALLET_ORIGIN)
# ROR_RP_ID=wallet.example.localhost
# Comma-separated extra allowed origins (optional)
# ROR_ALLOWED_ORIGINS=https://app1.example.com,https://app2.example.com

# Optional override (defaults to https://test.rpc.fastnear.com in this example)
# NEAR_RPC_URL=https://rpc.testnet.near.org

EXPECTED_ORIGIN=https://example.localhost
EXPECTED_WALLET_ORIGIN=https://wallet.example.localhost

# Session (optional; enables JWT + HttpOnly cookie)
JWT_SECRET=change-me
JWT_ISSUER=relay-server
JWT_AUDIENCE=tatchi-app
JWT_EXPIRES_SEC=86400
SESSION_COOKIE_NAME=w3a_session
SESSION_SAME_SITE=Lax

# Threshold Ed25519 (2p FROST) signing (optional)
# Share mode:
# - auto (default): derive relayer share if master secret is set, else use persisted share
# - derived: always derive relayer share (stateless relayer; recommended for clusters/serverless)
# - kv: always use persisted relayer share (requires Redis/Upstash or in-memory dev-only)
THRESHOLD_ED25519_SHARE_MODE=derived
# Required for share mode "derived" (32 bytes, base64url).
# node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
THRESHOLD_ED25519_MASTER_SECRET_B64U=
# Required for threshold ECDSA provisioning/signing.
# The relay server will fail to start if this is missing.
THRESHOLD_SECP256K1_MASTER_SECRET_B64U=

# Coordinator/cosigner wiring (optional; used when running a multi-process relay fleet).
# - coordinator exposes /threshold-ed25519/sign/*
# - cosigners expose /threshold-ed25519/internal/cosign/*
THRESHOLD_NODE_ROLE=coordinator
# Required for THRESHOLD_NODE_ROLE=cosigner.
# Each relayer process must have its own unique cosigner id (u16).
# THRESHOLD_ED25519_RELAYER_COSIGNER_ID=1
# Coordinator <-> cosigner shared secret for internal grants (32 bytes, base64url).
# node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
THRESHOLD_COORDINATOR_SHARED_SECRET_B64U=
# Optional: stable instance id for this coordinator.
# Used to pin threshold-ecdsa presign sessions to their owning coordinator.
# THRESHOLD_COORDINATOR_INSTANCE_ID=coordinator-a
# Optional: coordinator peer map for cross-instance presign-step forwarding.
# THRESHOLD_COORDINATOR_PEERS='[{"instanceId":"coordinator-a","relayerUrl":"https://relay-a.internal"},{"instanceId":"coordinator-b","relayerUrl":"https://relay-b.internal"}]'
#
# Multi-coordinator example (set on each coordinator):
# coordinator-a:
#   THRESHOLD_COORDINATOR_INSTANCE_ID=coordinator-a
#   THRESHOLD_COORDINATOR_PEERS='[{"instanceId":"coordinator-a","relayerUrl":"https://relay-server.localhost"},{"instanceId":"coordinator-b","relayerUrl":"https://relay-server2.localhost"},{"instanceId":"coordinator-c","relayerUrl":"https://relay-server3.localhost"}]'
# coordinator-b:
#   THRESHOLD_COORDINATOR_INSTANCE_ID=coordinator-b
#   THRESHOLD_COORDINATOR_PEERS='[{"instanceId":"coordinator-a","relayerUrl":"https://relay-server.localhost"},{"instanceId":"coordinator-b","relayerUrl":"https://relay-server2.localhost"},{"instanceId":"coordinator-c","relayerUrl":"https://relay-server3.localhost"}]'
# coordinator-c:
#   THRESHOLD_COORDINATOR_INSTANCE_ID=coordinator-c
#   THRESHOLD_COORDINATOR_PEERS='[{"instanceId":"coordinator-a","relayerUrl":"https://relay-server.localhost"},{"instanceId":"coordinator-b","relayerUrl":"https://relay-server2.localhost"},{"instanceId":"coordinator-c","relayerUrl":"https://relay-server3.localhost"}]'

# Relayer-fleet internal t-of-n cosigning (external signer set stays 2P: client + logical relayer).
# For local dev fleet mode, cosigner URLs are usually direct localhost HTTP (no TLS).
# THRESHOLD_ED25519_RELAYER_COSIGNERS='[{"cosignerId":1,"relayerUrl":"http://127.0.0.1:3000"},{"cosignerId":2,"relayerUrl":"http://127.0.0.1:3001"},{"cosignerId":3,"relayerUrl":"http://127.0.0.1:3002"}]'
# THRESHOLD_ED25519_RELAYER_COSIGNER_T=2

# Optional PRF session seal routes (server-side 3-pass unlock module):
# - POST /threshold-ecdsa/prf-seal/apply-server-seal
# - POST /threshold-ecdsa/prf-seal/remove-server-seal
# Enable only when you want refresh rehydrate support.
# PRF_SESSION_SEAL_ENABLED=1
# PRF_SESSION_SEAL_KEY_VERSION=kek-s-2026-02
# SHAMIR_P_B64U=
# SHAMIR_E_S_B64U=
# SHAMIR_D_S_B64U=
# Optional route rate limit config:
# PRF_SESSION_SEAL_RATE_LIMIT_KIND=in-memory # in-memory | upstash-redis-rest | redis-tcp
# PRF_SESSION_SEAL_RATE_LIMIT=30
# PRF_SESSION_SEAL_RATE_LIMIT_WINDOW_MS=60000
# PRF_SESSION_SEAL_RATE_LIMIT_KEY_PREFIX=threshold:prf-seal:rate:

# Optional persistence for threshold sessions (recommended for production).
# If omitted, the relayer uses in-memory stores (NOT safe across restarts/instances).
# Postgres (recommended for durable persistence)
POSTGRES_URL=postgres://tatchi:tatchi@localhost:5432/tatchi
# Upstash REST (Cloudflare-friendly)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Redis TCP (Node-only)
# REDIS_URL=redis://localhost:6379
# Note: when both POSTGRES_URL and REDIS_URL are set, this example prefers Postgres for threshold stores.

# Console/admin routes (mounted at /console/* in this example server)
# Dev-only bearer token required by console auth adapter.
CONSOLE_DEV_TOKEN=dev-console-token

# Console billing backend:
# - postgres: persists billing data in Postgres (recommended when POSTGRES_URL is set)
# - memory: in-memory billing data (ephemeral dev only)
# Defaults to "postgres" when POSTGRES_URL is set, otherwise "memory".
# CONSOLE_BILLING_BACKEND=postgres

# Namespace for console billing tables when using postgres backend.
# Useful when sharing one Postgres database across multiple relay instances.
# CONSOLE_BILLING_NAMESPACE=relay-console

# Console webhooks backend:
# - postgres: persists webhook endpoints/deliveries/attempts/dead-letters in Postgres
# - memory: in-memory webhook data (ephemeral dev only)
# Defaults to "postgres" when POSTGRES_URL is set, otherwise "memory".
# CONSOLE_WEBHOOKS_BACKEND=postgres

# Namespace for console webhook tables when using postgres backend.
# Useful when sharing one Postgres database across multiple relay instances.
# CONSOLE_WEBHOOKS_NAMESPACE=relay-console

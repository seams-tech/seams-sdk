# -----------------------------------------------------------------------------
# Relay and console origins
# -----------------------------------------------------------------------------
# Browser-facing relay origin used by the demo SDK.
VITE_RELAYER_URL=https://localhost:9444

# Optional dedicated console origin. Defaults to VITE_RELAYER_URL when unset.
# VITE_CONSOLE_BASE_URL=https://localhost:9444

# NEAR relayer account shown by the demo UI.
VITE_RELAYER_ACCOUNT_ID=w3a-relayer.testnet


# -----------------------------------------------------------------------------
# Google SSO
# -----------------------------------------------------------------------------
# Google SSO is configured on the relay with GOOGLE_OIDC_CLIENT_ID or
# GOOGLE_OIDC_CLIENT_IDS. The site reads public Google options from the relay;
# do not configure a site-side Google client id here.


# -----------------------------------------------------------------------------
# Managed registration and sponsorship
# -----------------------------------------------------------------------------
# Managed registration requires both values. Create a publishable key in the
# dashboard for the target environment, then set both values below.
#
# When configured, the site calls /v1/registration/bootstrap-grants and redeems
# the returned bootstrap_token. The same pair is used by the demo Tempo
# "Drip Fee Tokens" sponsorship action.
# VITE_SEAMS_ENVIRONMENT_ID=proj_example:dev
# VITE_SEAMS_PUBLISHABLE_KEY=pk_...


# -----------------------------------------------------------------------------
# Wallet iframe and relying-party metadata
# -----------------------------------------------------------------------------
# Wallet iframe origin used by wallet-iframe mode.
VITE_WALLET_ORIGIN=https://localhost:8443

# Documentation origin used by local ROR examples.
VITE_DOCS_ORIGIN=https://docs.localhost

# Base RP id for WebAuthn/ROR flows.
VITE_RP_ID_BASE=localhost

# Extra ROR origins served by wallet/dev plugins.
VITE_ROR_ALLOWED_ORIGINS=https://docs.localhost

# Demo contract account used by the local transaction examples.
VITE_DEMO_CONTRACT_ID=w3a-v1.testnet

# Optional SDK asset paths. Defaults are shown here for reference.
# VITE_WALLET_SERVICE_PATH=/wallet-service
# VITE_SDK_BASE_PATH=/sdk


# -----------------------------------------------------------------------------
# NEAR network
# -----------------------------------------------------------------------------
# VITE_NEAR_NETWORK=testnet
# VITE_NEAR_RPC_URL=https://test.rpc.fastnear.com
# VITE_NEAR_EXPLORER=https://testnet.nearblocks.io


# -----------------------------------------------------------------------------
# EVM demo networks
# -----------------------------------------------------------------------------
# Tempo testnet RPC used by Tempo signing and sponsorship demos.
VITE_TEMPO_RPC_URL=https://rpc.moderato.tempo.xyz
# VITE_TEMPO_EXPLORER=https://your-tempo-explorer.example

# Optional Tempo fee token used for Tempo tx fee settlement / setUserToken.
# VITE_TEMPO_FEE_TOKEN=0x20c0000000000000000000000000000000000001

# Arc-specific EVM network override for the demo's Arc testnet chain config.
VITE_ARC_RPC_URL=https://rpc.testnet.arc.network
# VITE_ARC_EXPLORER=https://your-arc-explorer.example


# -----------------------------------------------------------------------------
# Warm signing session policy
# -----------------------------------------------------------------------------
# Defaults: 1 day and 3 uses.
# VITE_SIGNING_SESSION_TTL_MS=86400000
# VITE_SIGNING_SESSION_REMAINING_USES=3


# -----------------------------------------------------------------------------
# Warm signing session sealed refresh
# -----------------------------------------------------------------------------
# Optional same-tab refresh without an extra TouchID/passkey prompt.
# Use `pnpm signing-session-seal:keygen` at repo root to generate matching relay/client
# values. The client prime must match relay SIGNING_SESSION_SHAMIR_P_B64U.
# VITE_SIGNING_SESSION_PERSISTENCE_MODE=sealed_refresh_v1
# VITE_SIGNING_SESSION_SEAL_KEY_VERSION=kek-s-2026-02
# VITE_SIGNING_SESSION_SHAMIR_P_B64U=<same as SIGNING_SESSION_SHAMIR_P_B64U on relay>


# -----------------------------------------------------------------------------
# Dashboard feature flags
# -----------------------------------------------------------------------------
# Set to false to hide wallets list/search routes from /dashboard navigation.
# VITE_DASHBOARD_WALLETS_ROUTES_ENABLED=true

# Relayer configuration
VITE_RELAYER_URL=https://localhost:9444
# Optional dedicated console origin; defaults to VITE_RELAYER_URL when unset
# VITE_CONSOLE_BASE_URL=https://localhost:9444
# Optional Google OIDC client ID used by the marketing-site dashboard auth modal.
# Must match relay GOOGLE_OIDC_CLIENT_ID(S) config for /session/exchange oidc_jwt.
# VITE_GOOGLE_OIDC_CLIENT_ID=

# Managed browser registration credentials.
# Create a publishable_key in the dashboard for the target environment, then set both values below.
# When configured, the site will call /v1/registration/bootstrap-grants first and redeem the returned bootstrap_token.
# VITE_TATCHI_ENVIRONMENT_ID=env_prod
# VITE_TATCHI_PUBLISHABLE_KEY=tpk_v1_...
# Optional override; set this to the relay origin and the site will append /v1/registration/bootstrap-grants
# VITE_TATCHI_BROKER_URL=https://localhost:9444

VITE_RELAYER_ACCOUNT_ID=w3a-relayer.testnet

# Wallet iframe configuration
VITE_WALLET_ORIGIN=https://localhost:8443
VITE_DOCS_ORIGIN=https://docs.localhost
VITE_RP_ID_BASE=localhost
VITE_ROR_ALLOWED_ORIGINS=https://docs.localhost
VITE_DEMO_CONTRACT_ID=w3a-v1.testnet

# Optional SDK asset base
# VITE_WALLET_SERVICE_PATH=/wallet-service
# VITE_SDK_BASE_PATH=/sdk

# Optional overrides
# VITE_NEAR_NETWORK=testnet
# VITE_NEAR_RPC_URL=https://test.rpc.fastnear.com
# VITE_NEAR_EXPLORER=https://testnet.nearblocks.io
VITE_TEMPO_RPC_URL=https://rpc.moderato.tempo.xyz
# VITE_TEMPO_EXPLORER=https://your-tempo-explorer.example
# Optional: Tempo fee token used for tempo tx fee settlement / setUserToken
# VITE_TEMPO_FEE_TOKEN=0x20c0000000000000000000000000000000000001
# Arc-specific EVM network override for the demo's Arc testnet chain config.
VITE_ARC_RPC_URL=https://rpc.testnet.arc.network
# VITE_ARC_EXPLORER=https://your-arc-explorer.example

# Warm signing session policy (default: 1 day, 10k uses)
# VITE_SIGNING_SESSION_TTL_MS=86400000
# VITE_SIGNING_SESSION_REMAINING_USES=10000

# Sealed refresh (optional, same-tab refresh without extra TouchID prompt)
# Use `pnpm prf-seal:keygen` at repo root to generate matching server/client values.
# VITE_SIGNING_SESSION_PERSISTENCE_MODE=sealed_refresh_v1
# VITE_SIGNING_SESSION_SEAL_KEY_VERSION=kek-s-2026-02-27
# VITE_SIGNING_SESSION_SHAMIR_P_B64U=<same as SHAMIR_P_B64U on relay>

# Dashboard feature flags
# Set to false to hide wallets list/search routes from /dashboard navigation
# VITE_DASHBOARD_WALLETS_ROUTES_ENABLED=true

# Relayer configuration
VITE_RELAYER_URL=https://pta-m4.local:8444
VITE_RELAYER_ACCOUNT_ID=w3a-relayer.testnet

# Wallet iframe configuration
VITE_WALLET_ORIGIN=https://pta-m4.local:8443
VITE_DOCS_ORIGIN=https://docs.example.localhost
VITE_RP_ID_BASE=pta-m4.local

# Optional SDK asset base
# VITE_WALLET_SERVICE_PATH=/wallet-service
# VITE_SDK_BASE_PATH=/sdk

# Optional overrides
# VITE_NEAR_NETWORK=testnet
# VITE_NEAR_RPC_URL=https://test.rpc.fastnear.com
# VITE_NEAR_EXPLORER=https://testnet.nearblocks.io
VITE_TEMPO_RPC_URL=https://rpc.moderato.tempo.xyz
# VITE_TEMPO_EXPLORER=https://your-tempo-explorer.example
# Optional: Tempo fee token used for tempo tx fee settlement / setUserToken
# VITE_TEMPO_FEE_TOKEN=0x20c0000000000000000000000000000000000001
# Arc-specific EVM network override for the demo's Arc testnet chain config.
VITE_ARC_RPC_URL=https://rpc.testnet.arc.network
# VITE_ARC_EXPLORER=https://your-arc-explorer.example
# Warm signing session policy (default: 1 day, 10k uses)
# VITE_SIGNING_SESSION_TTL_MS=86400000
# VITE_SIGNING_SESSION_REMAINING_USES=10000
